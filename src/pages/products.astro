---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Carbon Fiber Filament", "url": "https://amoscomposites.cn/products#filament" },
    { "@type": "ListItem", "position": 2, "name": "Chopped Carbon Fiber", "url": "https://amoscomposites.cn/products#chopped" },
    { "@type": "ListItem", "position": 3, "name": "Carbon Fiber Powder", "url": "https://amoscomposites.cn/products#powder" },
    { "@type": "ListItem", "position": 4, "name": "Carbon Fiber Fabric", "url": "https://amoscomposites.cn/products#fabric" },
    { "@type": "ListItem", "position": 5, "name": "Nickel-Plated Carbon Fiber", "url": "https://amoscomposites.cn/products#nickel" }
  ]
};
---

<Layout
  title="碳纤维产品_碳纤维丝_碳纤维布_镀镍碳纤维-碳烯技术(Amos Composites)"
  description="碳烯技术碳纤维产品系列：碳纤维丝(1K-24K)、短切碳纤维(PA/PP/PEEK改性)、碳纤维粉(50-300目)、碳纤维布(平纹/斜纹/缎纹)、镀镍碳纤维(EMI屏蔽)。Carbon fiber products for composite manufacturing."
  keywords="碳纤维产品,碳纤维丝,短切碳纤维,碳纤维粉,碳纤维布,镀镍碳纤维,碳纤维制品,碳纤维材料,carbon fiber products,carbon fiber filament,chopped carbon fiber,carbon fiber powder,carbon fiber fabric,nickel plated carbon fiber,PAN carbon fiber,carbon fiber composite"
  canonical="/products"
  schema={schema}
>
  <Header />

  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin-bottom: 12px;">Our Products / 产品系列</h1>
    <p style="color: #e2e8f0; max-width: 700px; margin: 0 auto; font-size: 1.1rem;">Comprehensive carbon fiber materials for composite manufacturing and plastic reinforcement. / 全面的碳纤维复合材料及塑料增强材料</p>
  </section>

  <!-- Carbon Fiber Filament -->
  <section id="filament" style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <div style="display: grid; grid-template-columns: 1fr; gap: 40px;">
      <div>
        <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px;">Carbon Fiber Filament / 碳纤维丝</h2>
        <p style="color: var(--text-light); line-height: 1.7; margin-bottom: 20px;">
          Continuous carbon fiber filament available in PAN-based and pitch-based variants. Standard specifications include 1K, 3K, 6K, 12K, 24K tow sizes with tensile strength up to 7.0 GPa.
        </p>
        <ul style="display: flex; flex-direction: column; gap: 8px; color: var(--text-light); font-size: 0.95rem;">
          <li>- PAN-based: T300, T700, T800 grade equivalent / PAN基：T300、T700、T800同级</li>
          <li>- Pitch-based: high modulus up to 900 GPa / 沥青基：高模量可达900 GPa</li>
          <li>- Compatible with epoxy, vinyl ester, phenolic resins / 兼容环氧、乙烯基酯、酚醛树脂</li>
          <li>- Surface treatment: sizing for thermoset / thermoplastic / 表面处理：热固/热塑性上浆剂</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Chopped Carbon Fiber -->
  <section id="chopped" style="background: var(--bg-alt); padding: 64px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px;">Chopped Carbon Fiber / 短切碳纤维</h2>
      <p style="color: var(--text-light); line-height: 1.7; margin-bottom: 24px; max-width: 800px;">
        Precision-cut short fibers optimized for plastic modification and injection molding. Available in agglomerated and bundle (flock) forms for improved dispersion in polymer matrices.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px;">
        <div style="background: white; padding: 24px; border-radius: 8px; border: 1px solid var(--border);">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">PA Modified / 尼龙改性</h4>
          <p style="color: var(--text-light); font-size: 0.9rem;">Nylon 6, PA66, PA12 reinforcement. Improved stiffness and heat resistance. / 尼龙6、PA66、PA12增强，提高刚性和耐热性</p>
        </div>
        <div style="background: white; padding: 24px; border-radius: 8px; border: 1px solid var(--border);">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">PP Modified / 聚丙烯改性</h4>
          <p style="color: var(--text-light); font-size: 0.9rem;">Polypropylene composite for automotive and appliance housings. / 汽车及家电外壳用聚丙烯复合材料</p>
        </div>
        <div style="background: white; padding: 24px; border-radius: 8px; border: 1px solid var(--border);">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">PEEK / PEI / 高性能热塑性塑料</h4>
          <p style="color: var(--text-light); font-size: 0.9rem;">High-performance thermoplastic for aerospace and medical applications. / 航空航天及医疗应用的高性能热塑性塑料</p>
        </div>
        <div style="background: white; padding: 24px; border-radius: 8px; border: 1px solid var(--border);">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">ABS / PPS / PU / 工程塑料</h4>
          <p style="color: var(--text-light); font-size: 0.9rem;">Engineering plastic reinforcement for electronics and industrial parts. / 电子及工业零部件用工程塑料增强</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Carbon Fiber Powder -->
  <section id="powder" style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px;">Carbon Fiber Powder / 碳纤维粉</h2>
    <p style="color: var(--text-light); line-height: 1.7; margin-bottom: 20px; max-width: 800px;">
      Milled carbon fiber powder for conductive fillers, EMI shielding compounds, and friction materials. Mesh sizes from 50 to 300 mesh with adjustable aspect ratio.
    </p>
    <ul style="display: flex; flex-direction: column; gap: 8px; color: var(--text-light); font-size: 0.95rem;">
      <li>- Milled from PAN or pitch-based precursor / PAN或沥青基前驱体研磨</li>
      <li>- Particle sizes: 50 mesh ~ 300 mesh / 粒度：50目~300目</li>
      <li>- Applications: conductive plastics, brake pads, coatings / 应用：导电塑料、刹车片、涂料</li>
      <li>- Bulk density and conductivity customizable / 堆积密度和导电性可定制</li>
    </ul>
  </section>

  <!-- Carbon Fiber Fabric -->
  <section id="fabric" style="background: var(--bg-alt); padding: 64px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px;">Carbon Fiber Fabric / 碳纤维布</h2>
      <p style="color: var(--text-light); line-height: 1.7; margin-bottom: 24px; max-width: 800px;">
        Woven carbon fiber fabrics in plain, twill 2/2, and satin weaves for hand layup, vacuum infusion, RTM, and prepreg manufacturing.
      </p>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
        <div style="padding: 20px; background: white; border-radius: 8px; border: 1px solid var(--border); text-align: center;">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">Plain Weave / 平纹</h4>
          <p style="color: var(--text-light); font-size: 0.9rem;">Balanced strength, easy draping / 强度均衡，易于铺覆</p>
        </div>
        <div style="padding: 20px; background: white; border-radius: 8px; border: 1px solid var(--border); text-align: center;">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">Twill 2/2 / 斜纹</h4>
          <p style="color: var(--text-light); font-size: 0.9rem;">Better conformability, premium look / 更好的贴合性，外观高级</p>
        </div>
        <div style="padding: 20px; background: white; border-radius: 8px; border: 1px solid var(--border); text-align: center;">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">Satin Weave / 缎纹</h4>
          <p style="color: var(--text-light); font-size: 0.9rem;">High conformability, aerospace grade / 高贴合性，航空级</p>
        </div>
        <div style="padding: 20px; background: white; border-radius: 8px; border: 1px solid var(--border); text-align: center;">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">Unidirectional / 单向布</h4>
          <p style="color: var(--text-light); font-size: 0.9rem;">Maximum directional strength / 最大方向强度</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Nickel-Plated -->
  <section id="nickel" style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px;">Nickel-Plated Carbon Fiber / 镀镍碳纤维</h2>
    <p style="color: var(--text-light); line-height: 1.7; margin-bottom: 20px; max-width: 800px;">
      Electroless nickel-plated carbon fiber for electromagnetic interference (EMI) shielding and electrostatic discharge (ESD) applications. Available as filament or powder.
    </p>
    <ul style="display: flex; flex-direction: column; gap: 8px; color: var(--text-light); font-size: 0.95rem;">
      <li>- Nickel coating thickness: 0.2 - 2.0 μm / 镍层厚度：0.2-2.0微米</li>
      <li>- Surface resistivity: < 0.1 Ω/sq / 表面电阻率：<0.1 Ω/sq</li>
      <li>- Shielding effectiveness: > 60 dB / 屏蔽效能：>60 dB</li>
      <li>- Available as filament (1K-24K) or powder (50-300 mesh) / 可提供丝束(1K-24K)或粉末(50-300目)</li>
    </ul>
  </section>

  <!-- CTA -->
  <section style="background: var(--primary); color: white; padding: 64px 24px; text-align: center;">
    <h2 style="font-size: 1.6rem; font-weight: 800; margin-bottom: 16px;">Need a Custom Specification? / 需要定制规格？</h2>
    <p style="color: #e2e8f0; max-width: 600px; margin: 0 auto 28px; font-size: 1.05rem;">We adjust fiber length, sizing, bundle size, and surface treatment to match your resin system. / 我们调整纤维长度、上浆剂、束丝尺寸和表面处理以匹配您的树脂体系。</p>
    <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; font-size: 1.05rem; display: inline-block; transition: background 0.2s;" onmouseover="this.style.background='#9b2c2c'" onmouseout="this.style.background='var(--accent)';">Request Custom Quote / 定制询价</a>
  </section>

  <Footer />
</Layout>