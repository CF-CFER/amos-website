---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "塑料改性碳纤维 - 懂塑料更懂碳纤维",
  "description": "碳烯技术塑料改性碳纤维专家：为PP、PE、ABS、HIPS、PA6、PA66、PC、POM、PBT、PET、PC/ABS、PMMA、TPU、PPO、LCP等塑料提供碳纤维增强解决方案。",
  "brand": { "@type": "Brand", "name": "碳烯技术" },
  "offers": { "@type": "Offer", "availability": "https://schema.org/InStock" }
};
---

<Layout
  title="塑料改性碳纤维_PP/PE/ABS/PA6/PA66/PC/POM_碳纤维增强塑料-碳烯技术"
  description="碳烯技术塑料改性碳纤维专家：为PP、PE、ABS、PA6、PA66、PC、POM、PBT、PET、TPU、PPO等塑料提供碳纤维增强方案。懂塑料更懂碳纤维，一站解决碳纤维分散、界面结合、性能提升。"
  keywords="塑料改性碳纤维,碳纤维增强塑料,碳纤维增强PP,碳纤维增强PA6,碳纤维增强PA66,碳纤维增强ABS,碳纤维增强PC,碳纤维增强POM,碳纤维增强PBT,碳纤维增强TPU,碳纤维增强PPO"
  canonical="/plastic-modified-carbon"
  schema={schema}
>
  <Header />

  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin-bottom: 12px;">
      塑料改性碳纤维 / Plastic Modified Carbon Fiber
    </h1>
    <p style="color: #e2e8f0; max-width: 900px; margin: 0 auto; font-size: 1.1rem;">
      懂塑料更懂碳纤维 · 一站解决碳纤维分散、界面结合、性能提升<br/>
      PP / PE / ABS / PA6 / PA66 / PC / POM / PBT / PET / TPU / PPO
    </p>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <div style="background: var(--accent); color: white; padding: 24px; border-radius: 12px; text-align: center; margin-bottom: 48px;">
      <h2 style="font-size: 1.4rem; font-weight: 800; margin-bottom: 12px;">
        为什么选碳烯技术？
      </h2>
      <p style="font-size: 1.05rem;">
        我们不做"把碳纤维扔进塑料里"的简单混合，
        我们懂塑料的流变特性、结晶行为、界面相容性，
        更懂碳纤维的表面处理、分散技术、取向控制。
        <strong>懂塑料 + 懂碳纤维 = 真正有效的改性方案</strong>
      </p>
    </div>

    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 32px; text-align: center;">
      覆盖15种塑料体系
    </h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 16px;">
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">PP</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">聚丙烯</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">PE</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">聚乙烯</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">ABS</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">丙烯腈-丁二烯-苯乙烯</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">HIPS</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">高抗冲聚苯乙烯</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">PA6</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">尼龙6</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">PA66</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">尼龙66</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">PC</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">聚碳酸酯</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">POM</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">聚甲醛</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">PBT</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">聚对苯二甲酸丁二醇酯</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">PET</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">聚对苯二甲酸乙二醇酯</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">PC/ABS</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">合金材料</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">PMMA</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">亚克力</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">TPU</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">热塑性聚氨酯</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">PPO</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">聚苯醚</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary);">LCP</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">液晶聚合物</p>
      </div>
    </div>
  </section>

  <section style="background: var(--bg-alt); padding: 64px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
        改性效果数据
      </h2>
      
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; margin-top: 24px; font-size: 0.9rem;">
          <thead>
            <tr style="background: var(--primary); color: white;">
              <th style="padding: 12px; text-align: left;">塑料类型</th>
              <th style="padding: 12px; text-align: left;">拉伸强度提升</th>
              <th style="padding: 12px; text-align: left;">弯曲模量提升</th>
              <th style="padding: 12px; text-align: left;">热变形温度提升</th>
              <th style="padding: 12px; text-align: left;">典型应用</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">PP + 碳纤维</td>
              <td style="padding: 12px;">+40-60%</td>
              <td style="padding: 12px;">+80-120%</td>
              <td style="padding: 12px;">+20-30℃</td>
              <td style="padding: 12px;">汽车保险杠、家电外壳</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">PA6 + 碳纤维</td>
              <td style="padding: 12px;">+50-70%</td>
              <td style="padding: 12px;">+100-150%</td>
              <td style="padding: 12px;">+30-50℃</td>
              <td style="padding: 12px;">齿轮、轴承、结构件</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">PA66 + 碳纤维</td>
              <td style="padding: 12px;">+50-70%</td>
              <td style="padding: 12px;">+100-150%</td>
              <td style="padding: 12px;">+40-60℃</td>
              <td style="padding: 12px;">高温结构件、连接器</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">PEEK + 碳纤维</td>
              <td style="padding: 12px;">+60-80%</td>
              <td style="padding: 12px;">+120-180%</td>
              <td style="padding: 12px;">+50-80℃</td>
              <td style="padding: 12px;">医疗器械、航空部件</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">ABS + 碳纤维</td>
              <td style="padding: 12px;">+40-50%</td>
              <td style="padding: 12px;">+60-100%</td>
              <td style="padding: 12px;">+15-25℃</td>
              <td style="padding: 12px;">电子产品外壳、结构件</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">PC + 碳纤维</td>
              <td style="padding: 12px;">+40-60%</td>
              <td style="padding: 12px;">+80-120%</td>
              <td style="padding: 12px;">+20-40℃</td>
              <td style="padding: 12px;">透明结构件、光学部件</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
      我们的核心能力
    </h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 24px; margin-top: 32px;">
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 12px;">🔬 懂塑料</h4>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.7;">
          <li>熟悉15种热塑性塑料的流变特性</li>
          <li>掌握塑料结晶行为与碳纤维的相互作用</li>
          <li>了解不同塑料的加工窗口和工艺限制</li>
        </ul>
      </div>
      
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 12px;">🧪 懂碳纤维</h4>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.7;">
          <li>碳纤维表面处理技术（氧化、涂层、偶联剂）</li>
          <li>碳纤维在塑料中的分散技术</li>
          <li>碳纤维取向控制（注塑流动方向优化）</li>
        </ul>
      </div>
      
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 12px;">⚙️ 懂工艺</h4>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.7;">
          <li>注塑成型参数优化（温度/压力/速度）</li>
          <li>挤出成型工艺调试</li>
          <li>模压成型和热压罐工艺</li>
        </ul>
      </div>
      
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 12px;">📊 懂测试</h4>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.7;">
          <li>力学性能测试（拉伸/弯曲/冲击）</li>
          <li>热性能测试（HDT/TGA/DSC）</li>
          <li>微观结构分析（SEM/界面结合）</li>
        </ul>
      </div>
    </div>
  </section>

  <section style="background: var(--primary); color: white; padding: 64px 24px; text-align: center;">
    <h2 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 16px;">
      获取塑料改性碳纤维方案
    </h2>
    <p style="color: #e2e8f0; max-width: 600px; margin: 0 auto 28px; font-size: 1.05rem;">
      告诉我们您的塑料类型和应用场景，24小时内提供定制化碳纤维增强方案
    </p>
    <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; font-size: 1.05rem; display: inline-block;">
      获取方案 / Get Solution
    </a>
  </section>

  <Footer />
</Layout>