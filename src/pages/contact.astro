---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Amos Composites",
  "url": "https://amoscomposites.cn/contact.html",
  "mainEntity": {
    "@type": "Organization",
    "name": "Amos Composites Technology (Shenzhen) Co., Ltd.",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "sales",
      "email": "info@amoscomposites.cn"
    },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Shenzhen",
      "addressCountry": "CN"
    }
  }
};
---

<Layout
  title="Contact Us | Amos Composites - Request a Quote"
  description="Contact Amos Composites for carbon fiber product inquiries, custom specifications, and quotations. Response within 24 hours."
  keywords="contact carbon fiber supplier, carbon fiber quote, carbon fiber inquiry, custom carbon fiber order"
  canonical="/contact.html"
  schema={schema}
>
  <Header />

  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin-bottom: 12px;">Contact Us</h1>
    <p style="color: #e2e8f0; max-width: 700px; margin: 0 auto; font-size: 1.1rem;">Get a technical consultation or quotation within 24 hours.</p>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 48px;">
      
      <!-- Contact Info -->
      <div>
        <h2 style="font-size: 1.4rem; font-weight: 800; color: var(--primary); margin-bottom: 24px;">Get in Touch</h2>
        
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <div>
            <h4 style="font-weight: 700; margin-bottom: 4px; font-size: 0.95rem;">Email</h4>
            <p style="color: var(--text-light); font-size: 0.95rem;">info@amoscomposites.cn</p>
          </div>
          <div>
            <h4 style="font-weight: 700; margin-bottom: 4px; font-size: 0.95rem;">Phone / WhatsApp</h4>
            <p style="color: var(--text-light); font-size: 0.95rem;">+86-xxx-xxxx-xxxx</p>
          </div>
          <div>
            <h4 style="font-weight: 700; margin-bottom: 4px; font-size: 0.95rem;">Address</h4>
            <p style="color: var(--text-light); font-size: 0.95rem;">Shenzhen, Guangdong, China</p>
          </div>
          <div>
            <h4 style="font-weight: 700; margin-bottom: 4px; font-size: 0.95rem;">Business Hours</h4>
            <p style="color: var(--text-light); font-size: 0.95rem;">Monday - Saturday: 9:00 - 18:00 (GMT+8)</p>
          </div>
        </div>
      </div>

      <!-- Inquiry Form -->
      <div>
        <h2 style="font-size: 1.4rem; font-weight: 800; color: var(--primary); margin-bottom: 24px;">Request a Quote</h2>
        
        <form id="inquiry-form" style="display: flex; flex-direction: column; gap: 16px;">
          <div>
            <label style="display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 6px;">Name *</label>
            <input type="text" name="name" required style="width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 1rem;" />
          </div>
          <div>
            <label style="display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 6px;">Email / WhatsApp / Phone *</label>
            <input type="text" name="contact" required placeholder="Enter your email, WhatsApp or phone number" style="width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 1rem;" />
          </div>
          <div>
            <label style="display: block; font-weight: 600; font-size: 0.9rem; margin-bottom: 6px;">Message / Inquiry Details</label>
            <textarea name="message" rows="5" placeholder="Describe your needs, product requirements, or questions..." style="width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 1rem; resize: vertical;"></textarea>
          </div>
          <button type="submit" id="submit-btn" style="background: var(--accent); color: white; padding: 14px; border: none; border-radius: 8px; font-weight: 700; font-size: 1rem; cursor: pointer; transition: background 0.2s;" onmouseover="this.style.background='#9b2c2c'" onmouseout="this.style.background='var(--accent)'">Submit Inquiry</button>
        </form>
        
        <p id="form-status" style="margin-top: 12px; font-size: 0.95rem; min-height: 1.5rem;"></p>
        
        <p style="margin-top: 8px; color: var(--text-light); font-size: 0.85rem;">
          * For immediate response, you may also email us directly at <a href="mailto:info@amoscomposites.cn" style="color: var(--accent);">info@amoscomposites.cn</a>
        </p>
      </div>
      
    </div>
  </section>

  <script is:inline>
    document.getElementById('inquiry-form').addEventListener('submit', async function(e) {
      e.preventDefault();
      const form = e.target;
      const btn = document.getElementById('submit-btn');
      const status = document.getElementById('form-status');
      
      btn.disabled = true;
      btn.textContent = 'Sending...';
      status.textContent = '';
      status.style.color = '';
      
      const data = {
        name: form.name.value.trim(),
        contact: form.contact.value.trim(),
        message: form.message.value.trim()
      };
      
      try {
        const res = await fetch('/api/inquiry', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data)
        });
        const result = await res.json();
        
        if (result.success) {
          status.style.color = '#15803d';
          status.textContent = '✅ Thank you! Your inquiry has been sent. We will respond within 24 hours.';
          form.reset();
        } else {
          status.style.color = '#b91c1c';
          status.textContent = '❌ Error: ' + (result.error || 'Failed to send inquiry. Please try again.');
        }
      } catch (err) {
        status.style.color = '#b91c1c';
        status.textContent = '❌ Network error. Please try again or email us directly at info@amoscomposites.cn';
      } finally {
        btn.disabled = false;
        btn.textContent = 'Submit Inquiry';
      }
    });
  </script>

  <Footer />
</Layout>