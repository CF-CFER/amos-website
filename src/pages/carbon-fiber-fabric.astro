---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "碳纤维布 - 表观布·加固布",
  "description": "碳烯技术碳纤维布专业分类：表观布（装饰用）和加固布（结构用）。3K/6K/12K平纹/斜纹/缎纹/单向布，200g/400g全规格。",
  "brand": { "@type": "Brand", "name": "Amos Composites" },
  "offers": { "@type": "Offer", "availability": "https://schema.org/InStock" }
};
---

<Layout
  title="碳纤维布_表观布_加固布_碳纤维布厂家-碳烯技术"
  description="碳烯技术碳纤维布专业供应商：表观布（装饰用，表面效果好）和加固布（结构用，强度优先）。3K/6K/12K平纹/斜纹/缎纹/单向布，200g/400g全规格。"
  keywords="碳纤维布,碳纤维布厂家,碳纤维布平纹,碳纤维布斜纹,碳纤维布200g,碳纤维布400g,表观布,加固布,碳纤维布价格"
  canonical="/carbon-fiber-fabric"
  schema={schema}
>
  <Header />

  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin-bottom: 12px;">
      碳纤维布 / Carbon Fiber Fabric
    </h1>
    <p style="color: #e2e8f0; max-width: 800px; margin: 0 auto; font-size: 1.1rem;">
      表观布 · 加固布 · 专业分类<br/>
      3K/6K/12K平纹/斜纹/缎纹/单向布 · 200g/400g全规格
    </p>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <div style="background: var(--accent); color: white; padding: 24px; border-radius: 12px; text-align: center; margin-bottom: 48px;">
      <h2 style="font-size: 1.4rem; font-weight: 800; margin-bottom: 12px;">碳纤维布分类：表观布 vs 加固布</h2>
      <p style="font-size: 1.05rem;">大多数供应商把碳纤维布混在一起卖，客户买回去才发现：做装饰的布强度不够，做加固的布外观不好。<strong>碳烯技术首创专业分类，让您不再买错！</strong></p>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px;">
      <div style="padding: 32px; background: var(--bg-alt); border-radius: 12px; border: 1px solid var(--border);">
        <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px;">🎨 表观布 / 装饰用碳纤维布</h3>
        <p style="color: var(--text-light); font-size: 0.95rem; line-height: 1.7; margin-bottom: 16px;">专为表面装饰效果设计，外观精美，纹路清晰</p>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>特点：外观精美、纹路清晰、表面平整</li>
          <li>常用：3K平纹、3K斜纹、3K缎纹</li>
          <li>克重：200g/㎡为主</li>
          <li>应用：汽车内饰、工艺品、运动器材表面、装饰件</li>
          <li>要求：表面无瑕疵、纹路对称、色泽均匀</li>
        </ul>
      </div>
      
      <div style="padding: 32px; background: var(--bg-alt); border-radius: 12px; border: 1px solid var(--border);">
        <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px;">🏗️ 加固布 / 结构用碳纤维布</h3>
        <p style="color: var(--text-light); font-size: 0.95rem; line-height: 1.7; margin-bottom: 16px;">专为结构补强设计，强度优先，承载力强</p>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>特点：强度高、承载力强、层间结合好</li>
          <li>常用：12K单向布、6K平纹、12K平纹</li>
          <li>克重：400g/㎡为主，也可定制600g/㎡</li>
          <li>应用：建筑加固、桥梁补强、风电叶片、汽车结构件</li>
          <li>要求：拉伸强度高、与树脂浸润性好</li>
        </ul>
      </div>
    </div>
  </section>

  <section style="background: var(--bg-alt); padding: 64px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">碳纤维布规格参数表</h2>
      
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; margin-top: 24px; font-size: 0.9rem;">
          <thead>
            <tr style="background: var(--primary); color: white;">
              <th style="padding: 12px; text-align: left;">规格</th>
              <th style="padding: 12px; text-align: left;">纹路</th>
              <th style="padding: 12px; text-align: left;">克重</th>
              <th style="padding: 12px; text-align: left;">宽度</th>
              <th style="padding: 12px; text-align: left;">拉伸强度</th>
              <th style="padding: 12px; text-align: left;">适用类型</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">3K平纹</td>
              <td style="padding: 12px;">方格纹</td>
              <td style="padding: 12px;">200g/㎡</td>
              <td style="padding: 12px;">1m</td>
              <td style="padding: 12px;">≥3500 MPa</td>
              <td style="padding: 12px;">表观布✅</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">3K斜纹</td>
              <td style="padding: 12px;">斜向纹路</td>
              <td style="padding: 12px;">200g/㎡</td>
              <td style="padding: 12px;">1m</td>
              <td style="padding: 12px;">≥3500 MPa</td>
              <td style="padding: 12px;">表观布✅</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">3K缎纹</td>
              <td style="padding: 12px;">光泽度高</td>
              <td style="padding: 12px;">200g/㎡</td>
              <td style="padding: 12px;">1m</td>
              <td style="padding: 12px;">≥3500 MPa</td>
              <td style="padding: 12px;">表观布✅</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">6K平纹</td>
              <td style="padding: 12px;">方格纹</td>
              <td style="padding: 12px;">400g/㎡</td>
              <td style="padding: 12px;">1m</td>
              <td style="padding: 12px;">≥3500 MPa</td>
              <td style="padding: 12px;">加固布✅</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">12K平纹</td>
              <td style="padding: 12px;">方格纹</td>
              <td style="padding: 12px;">400g/㎡</td>
              <td style="padding: 12px;">1m</td>
              <td style="padding: 12px;">≥3500 MPa</td>
              <td style="padding: 12px;">加固布✅</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">12K单向布</td>
              <td style="padding: 12px;">单向纤维</td>
              <td style="padding: 12px;">400g/㎡</td>
              <td style="padding: 12px;">1m</td>
              <td style="padding: 12px;">≥4000 MPa</td>
              <td style="padding: 12px;">加固布✅</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section style="background: var(--primary); color: white; padding: 64px 24px; text-align: center;">
    <h2 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 16px;">获取碳纤维布报价</h2>
    <p style="color: #e2e8f0; max-width: 600px; margin: 0 auto 28px; font-size: 1.05rem;">告诉我们您的应用场景（装饰/加固），推荐最适合的碳纤维布规格</p>
    <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; font-size: 1.05rem; display: inline-block;">获取报价 / Get Quote</a>
  </section>

  <Footer />
</Layout>