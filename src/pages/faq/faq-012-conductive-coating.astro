---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "导电涂料用多少目碳纤维粉最好？",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "导电涂料推荐200-300目碳纤维粉。200目（~75μm，粒径63-90μm）在环氧/丙烯酸/聚氨酯涂料中分散性良好，添加8-12%可达表面电阻率10的3-4次方Ω/sq，电磁屏蔽效能40-50dB（@1GHz）。300目（~50μm，粒径40-63μm）分散性更佳，涂料表面更光滑，添加6-10%即可达到相同导电效果，但成本比200目高约20-30%。50-100目粉体在涂料中易沉降、分散不均，不推荐。500目（~30μm）适合高端导电涂料和精密喷涂，但成本更高。使用技巧：1）配合分散剂（如BYK-110、Disperbyk-163），添加量0.5-1.5%；2）高速搅拌2000rpm，30...",
      "datePublished": "2026-07-02"
    }
  }]
};

const title = "导电涂料用多少目碳纤维粉最好？200目vs300目实测对比 | 碳烯技术";
const description = "导电涂料推荐200-300目碳纤维粉。200目添加8-12%可达屏蔽效能40-50dB，300目分散性更佳。";
---

<Layout title={title} description={description} canonical="/faq/faq-012-conductive-coating" schema={schema}>
  <Header />
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; max-width: 900px; margin: 0 auto;">导电涂料用多少目碳纤维粉最好？</h1>
  </section>

  <section style="padding: 64px 24px; max-width: 800px; margin: 0 auto;">
    <div style="background: white; padding: 40px; border-radius: 12px; border: 1px solid var(--border); line-height: 1.8; color: var(--text);">
      <div style="color: var(--text-light); line-height: 1.8;">
        <p style="margin-bottom: 16px;">导电涂料推荐200-300目碳纤维粉。200目（~75μm，粒径63-90μm）在环氧/丙烯酸/聚氨酯涂料中分散性良好，添加8-12%可达表面电阻率10的3-4次方Ω/sq，电磁屏蔽效能40-50dB（@1GHz）。300目（~50μm，粒径40-63μm）分散性更佳，涂料表面更光滑，添加6-10%即可达到相同导电效果，但成本比200目高约20-30%。50-100目粉体在涂料中易沉降、分散不均，不推荐。500目（~30μm）适合高端导电涂料和精密喷涂，但成本更高。使用技巧：1）配合分散剂（如BYK-110、Disperbyk-163），添加量0.5-1.5%；2）高速搅拌2000rpm，30分钟以上；3）研磨至细度小于等于20μm；4）添加触变剂（气相二氧化硅）防止沉降。碳烯技术提供导电涂料专用表面处理碳纤维粉，分散性提升40%，并提供涂料配方技术支持。</p>
      </div>

      <div style="background: var(--bg-alt); padding: 24px; border-radius: 8px; margin-top: 32px;">
        <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 12px;">相关型号推荐</h3>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>200目导电粉（通用，8-12%添加）</li>
          <li>300目导电粉（高端，6-10%添加）</li>
          <li>500目超细导电粉（精密涂料）</li>
          <li>镀镍碳纤维粉（高导电，5-8%添加）</li>
        </ul>
      </div>

      <div style="text-align: center; margin-top: 32px;">
        <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; display: inline-block;">获取方案与报价</a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
