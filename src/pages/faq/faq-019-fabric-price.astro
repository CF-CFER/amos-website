---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "碳纤维布多少钱一平方米？2026年价格",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "2026年碳纤维布价格参考（含税）：国产3K平纹200g约15-25元/㎡，国产3K斜纹200g约18-30元/㎡，国产3K缎纹200g约20-35元/㎡，国产6K平纹400g约20-30元/㎡，国产12K平纹400g约20-35元/㎡。进口东丽3K平纹200g约50-80元/㎡，进口东丽3K斜纹200g约60-100元/㎡。加固布（12K单向400g）约25-40元/㎡，表观布（3K平纹200g）约20-35元/㎡。进口布价格约为国产的2-3倍，但纤维质量、编织精度、批次稳定性更优。价格随原料品牌、编织工艺、幅宽、订单量波动。碳烯技术提供样品裁剪（最小5㎡起），批量100㎡以上有折扣。选型建...",
      "datePublished": "2026-07-02"
    }
  }]
};

const title = "碳纤维布多少钱一平方米？2026年价格参考与克重对比 | 碳烯技术";
const description = "国产3K平纹200g约15-25元/㎡，进口东丽3K平纹约50-80元/㎡。了解各规格价格区间。";
---

<Layout title={title} description={description} canonical="/faq/faq-019-fabric-price" schema={schema}>
  <Header />
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; max-width: 900px; margin: 0 auto;">碳纤维布多少钱一平方米？2026年价格</h1>
  </section>

  <section style="padding: 64px 24px; max-width: 800px; margin: 0 auto;">
    <div style="background: white; padding: 40px; border-radius: 12px; border: 1px solid var(--border); line-height: 1.8; color: var(--text);">
      <div style="color: var(--text-light); line-height: 1.8;">
        <p style="margin-bottom: 16px;">2026年碳纤维布价格参考（含税）：国产3K平纹200g约15-25元/㎡，国产3K斜纹200g约18-30元/㎡，国产3K缎纹200g约20-35元/㎡，国产6K平纹400g约20-30元/㎡，国产12K平纹400g约20-35元/㎡。进口东丽3K平纹200g约50-80元/㎡，进口东丽3K斜纹200g约60-100元/㎡。加固布（12K单向400g）约25-40元/㎡，表观布（3K平纹200g）约20-35元/㎡。进口布价格约为国产的2-3倍，但纤维质量、编织精度、批次稳定性更优。价格随原料品牌、编织工艺、幅宽、订单量波动。碳烯技术提供样品裁剪（最小5㎡起），批量100㎡以上有折扣。选型建议：结构加固选12K单向400g，汽车装饰选3K平纹/斜纹200g，船舶选6K/12K平纹400g+乙烯基酯。</p>
      </div>

      <div style="background: var(--bg-alt); padding: 24px; border-radius: 8px; margin-top: 32px;">
        <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 12px;">相关型号推荐</h3>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>国产3K平纹200g（15-25元/㎡）</li>
          <li>进口东丽3K平纹200g（50-80元/㎡）</li>
          <li>12K单向400g加固布（25-40元/㎡）</li>
          <li>3K斜纹200g表观布（18-30元/㎡）</li>
        </ul>
      </div>

      <div style="text-align: center; margin-top: 32px;">
        <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; display: inline-block;">获取方案与报价</a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
