---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "100目和300目碳纤维粉怎么选？",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "100目和300目碳纤维粉的选择取决于应用类型。100目（~150μm，粒径范围125-180μm）：长径比10-20，增强效果好，成本较低，适合塑料改性增强（PP/PA/ABS）、摩擦材料（刹车片）、建筑水泥增强。在塑料中分散性良好，但表面可能有轻微颗粒感。200目（~75μm，粒径范围63-90μm）：通用型，兼顾分散性和增强效果，适合塑料改性、导电涂料、一般工业应用。300目（~50μm，粒径范围40-63μm）：分散性最佳，适合高端导电涂料、精密塑料改性、电池浆料、特种填料。500目（~30μm，粒径范围20-40μm）：超细粉，适合高端涂料、精细填料、电池导电剂、半导体封装。原则：涂...",
      "datePublished": "2026-07-02"
    }
  }]
};

const title = "100目和300目碳纤维粉怎么选？目数选择与应用匹配指南 | 碳烯技术";
const description = "100目（~150μm）适合塑料增强和摩擦材料，300目（~50μm）适合高端涂料。了解各目数适用场景。";
---

<Layout title={title} description={description} canonical="/faq/faq-009-mesh-selection" schema={schema}>
  <Header />
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; max-width: 900px; margin: 0 auto;">100目和300目碳纤维粉怎么选？</h1>
  </section>

  <section style="padding: 64px 24px; max-width: 800px; margin: 0 auto;">
    <div style="background: white; padding: 40px; border-radius: 12px; border: 1px solid var(--border); line-height: 1.8; color: var(--text);">
      <div style="color: var(--text-light); line-height: 1.8;">
        <p style="margin-bottom: 16px;">100目和300目碳纤维粉的选择取决于应用类型。100目（~150μm，粒径范围125-180μm）：长径比10-20，增强效果好，成本较低，适合塑料改性增强（PP/PA/ABS）、摩擦材料（刹车片）、建筑水泥增强。在塑料中分散性良好，但表面可能有轻微颗粒感。200目（~75μm，粒径范围63-90μm）：通用型，兼顾分散性和增强效果，适合塑料改性、导电涂料、一般工业应用。300目（~50μm，粒径范围40-63μm）：分散性最佳，适合高端导电涂料、精密塑料改性、电池浆料、特种填料。500目（~30μm，粒径范围20-40μm）：超细粉，适合高端涂料、精细填料、电池导电剂、半导体封装。原则：涂料选细目（200-500目），增强选中粗目（100-200目），摩擦选粗目（50-100目），电池导电选超细目（300-500目）。碳烯技术提供50目至500目全规格，支持定制目数。</p>
      </div>

      <div style="background: var(--bg-alt); padding: 24px; border-radius: 8px; margin-top: 32px;">
        <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 12px;">相关型号推荐</h3>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>50-100目（摩擦材料/建筑）</li>
          <li>100-200目（塑料增强通用）</li>
          <li>200-300目（导电涂料）</li>
          <li>300-500目（精细填料/电池）</li>
        </ul>
      </div>

      <div style="text-align: center; margin-top: 32px;">
        <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; display: inline-block;">获取方案与报价</a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
