---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "表观布和加固布可以互相替代吗？",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "表观布和加固布不可以直接互相替代。表观布（装饰用碳纤维布）：纤维排列整齐美观，经纬张力均匀，表面无瑕疵，纹路对称，色泽均匀，上浆剂优化外观和树脂浸润性，但可能牺牲部分强度指标。适合汽车内饰、工艺品、运动器材表面、装饰件。加固布（结构用碳纤维布）：强度优先，纤维张力控制严格，与结构树脂浸润性更好，层间剪切强度高，但表面纹路可能不够精美。适合建筑加固、桥梁补强、风电叶片、汽车结构件。互相替代的后果：用表观布做结构加固，层间剪切强度可能低20-30%，承载能力不足；用加固布做外观装饰，表面纹路可能不够精美，影响产品卖相。碳烯技术首创专业分类：表观布专供装饰场景（3K平纹/斜纹/缎纹200g），加固布...",
      "datePublished": "2026-07-02"
    }
  }]
};

const title = "表观布和加固布可以互相替代吗？专业分类避免买错 | 碳烯技术";
const description = "不可以。表观布做结构强度低20-30%，加固布做外观纹路不够精美。碳烯技术首创专业分类。";
---

<Layout title={title} description={description} canonical="/faq/faq-024-appearance-vs-structural" schema={schema}>
  <Header />
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; max-width: 900px; margin: 0 auto;">表观布和加固布可以互相替代吗？</h1>
  </section>

  <section style="padding: 64px 24px; max-width: 800px; margin: 0 auto;">
    <div style="background: white; padding: 40px; border-radius: 12px; border: 1px solid var(--border); line-height: 1.8; color: var(--text);">
      <div style="color: var(--text-light); line-height: 1.8;">
        <p style="margin-bottom: 16px;">表观布和加固布不可以直接互相替代。表观布（装饰用碳纤维布）：纤维排列整齐美观，经纬张力均匀，表面无瑕疵，纹路对称，色泽均匀，上浆剂优化外观和树脂浸润性，但可能牺牲部分强度指标。适合汽车内饰、工艺品、运动器材表面、装饰件。加固布（结构用碳纤维布）：强度优先，纤维张力控制严格，与结构树脂浸润性更好，层间剪切强度高，但表面纹路可能不够精美。适合建筑加固、桥梁补强、风电叶片、汽车结构件。互相替代的后果：用表观布做结构加固，层间剪切强度可能低20-30%，承载能力不足；用加固布做外观装饰，表面纹路可能不够精美，影响产品卖相。碳烯技术首创专业分类：表观布专供装饰场景（3K平纹/斜纹/缎纹200g），加固布专供结构场景（12K单向/平纹400g），让您不再买错。同时提供混合方案：表观布做面层+加固布做结构层，兼顾外观和强度。</p>
      </div>

      <div style="background: var(--bg-alt); padding: 24px; border-radius: 8px; margin-top: 32px;">
        <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 12px;">相关型号推荐</h3>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>3K平纹200g表观布（装饰）</li>
          <li>3K斜纹200g表观布（汽车内饰）</li>
          <li>12K单向400g加固布（结构）</li>
          <li>12K平纹400g加固布（建筑）</li>
        </ul>
      </div>

      <div style="text-align: center; margin-top: 32px;">
        <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; display: inline-block;">获取方案与报价</a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
