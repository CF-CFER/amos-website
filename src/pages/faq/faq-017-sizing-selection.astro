---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "短切碳纤维上浆剂怎么选？",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "短切碳纤维上浆剂的选择直接影响复合材料界面结合强度，不匹配是导致改性失败的首要原因。环氧树脂体系选环氧上浆剂（界面剪切强度提升40%）；PA6/PA66选尼龙专用上浆剂（含氨基/羧基官能团，界面剪切强度提升50%）；PP选PP专用上浆剂或添加马来酸酐接枝聚丙烯（MAH-g-PP）偶联剂（相容性提升60%）；PEEK选高温上浆剂（耐温大于等于400℃，含热稳定基团）；PPS选PPS专用上浆剂（耐化学腐蚀）；ABS选通用上浆剂或丙烯酸类上浆；PC选通用上浆剂或聚氨酯类；TPU选聚氨酯专用上浆；PBT选PBT专用上浆或环氧类。上浆剂不匹配的后果：界面结合强度下降30-50%，复合材料拉伸强度和弯曲模...",
      "datePublished": "2026-07-02"
    }
  }]
};

const title = "短切碳纤维上浆剂怎么选？15种基体专用上浆剂匹配指南 | 碳烯技术";
const description = "环氧树脂选环氧上浆；PA66选尼龙专用上浆；PP选PP专用或MAH接枝。上浆剂不匹配会导致强度下降30-50%。";
---

<Layout title={title} description={description} canonical="/faq/faq-017-sizing-selection" schema={schema}>
  <Header />
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; max-width: 900px; margin: 0 auto;">短切碳纤维上浆剂怎么选？</h1>
  </section>

  <section style="padding: 64px 24px; max-width: 800px; margin: 0 auto;">
    <div style="background: white; padding: 40px; border-radius: 12px; border: 1px solid var(--border); line-height: 1.8; color: var(--text);">
      <div style="color: var(--text-light); line-height: 1.8;">
        <p style="margin-bottom: 16px;">短切碳纤维上浆剂的选择直接影响复合材料界面结合强度，不匹配是导致改性失败的首要原因。环氧树脂体系选环氧上浆剂（界面剪切强度提升40%）；PA6/PA66选尼龙专用上浆剂（含氨基/羧基官能团，界面剪切强度提升50%）；PP选PP专用上浆剂或添加马来酸酐接枝聚丙烯（MAH-g-PP）偶联剂（相容性提升60%）；PEEK选高温上浆剂（耐温大于等于400℃，含热稳定基团）；PPS选PPS专用上浆剂（耐化学腐蚀）；ABS选通用上浆剂或丙烯酸类上浆；PC选通用上浆剂或聚氨酯类；TPU选聚氨酯专用上浆；PBT选PBT专用上浆或环氧类。上浆剂不匹配的后果：界面结合强度下降30-50%，复合材料拉伸强度和弯曲模量大幅降低，注塑制品表面浮纤严重。碳烯技术提供15种基体专用上浆剂，覆盖PP/PA/PEEK/ABS/PC/PBT/TPU/PPS等所有主流塑料。支持定制上浆剂配方。</p>
      </div>

      <div style="background: var(--bg-alt); padding: 24px; border-radius: 8px; margin-top: 32px;">
        <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 12px;">相关型号推荐</h3>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>环氧专用上浆剂（环氧树脂基体）</li>
          <li>尼龙专用上浆剂（PA6/PA66）</li>
          <li>PP专用上浆剂（聚丙烯）</li>
          <li>高温上浆剂（PEEK/PPS）</li>
        </ul>
      </div>

      <div style="text-align: center; margin-top: 32px;">
        <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; display: inline-block;">获取方案与报价</a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
