---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "5G基站屏蔽用镀镍碳纤维丝还是粉？",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "5G基站EMI屏蔽推荐方案：外壳屏蔽：镀镍碳纤维丝编织布（1K-3K）+导电胶贴合，屏蔽效能60-65dB，重量比铜箔轻70%，适合基站外壳、机柜内衬。涂料屏蔽：镀镍碳纤维粉（200-300目）+导电环氧涂料，喷涂于塑料外壳内侧，屏蔽效能40-50dB，成本低，适合已有塑料外壳的 retrofit。垫片屏蔽：镀镍短切碳纤维+硅胶模压，压缩回弹好，屏蔽效能30-40dB，适合门缝、接口密封。线缆屏蔽：镀镍碳纤维丝编织屏蔽层，替代铜编织，减重50%，适合射频线缆。5G频段（sub-6GHz和毫米波）对屏蔽要求更高，sub-6GHz需大于等于40dB，毫米波需大于等于50dB。建议丝编织布方案（60...",
      "datePublished": "2026-07-02"
    }
  }]
};

const title = "5G基站屏蔽用镀镍碳纤维丝还是粉？全形态方案对比与选型建议 | 碳烯技术";
const description = "外壳屏蔽推荐丝编织布（60-65dB），涂料屏蔽推荐粉（40-50dB），垫片推荐短切+硅胶（30-40dB）。";
---

<Layout title={title} description={description} canonical="/faq/faq-028-5g-shielding" schema={schema}>
  <Header />
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; max-width: 900px; margin: 0 auto;">5G基站屏蔽用镀镍碳纤维丝还是粉？</h1>
  </section>

  <section style="padding: 64px 24px; max-width: 800px; margin: 0 auto;">
    <div style="background: white; padding: 40px; border-radius: 12px; border: 1px solid var(--border); line-height: 1.8; color: var(--text);">
      <div style="color: var(--text-light); line-height: 1.8;">
        <p style="margin-bottom: 16px;">5G基站EMI屏蔽推荐方案：外壳屏蔽：镀镍碳纤维丝编织布（1K-3K）+导电胶贴合，屏蔽效能60-65dB，重量比铜箔轻70%，适合基站外壳、机柜内衬。涂料屏蔽：镀镍碳纤维粉（200-300目）+导电环氧涂料，喷涂于塑料外壳内侧，屏蔽效能40-50dB，成本低，适合已有塑料外壳的 retrofit。垫片屏蔽：镀镍短切碳纤维+硅胶模压，压缩回弹好，屏蔽效能30-40dB，适合门缝、接口密封。线缆屏蔽：镀镍碳纤维丝编织屏蔽层，替代铜编织，减重50%，适合射频线缆。5G频段（sub-6GHz和毫米波）对屏蔽要求更高，sub-6GHz需大于等于40dB，毫米波需大于等于50dB。建议丝编织布方案（60-65dB）满足所有5G频段。碳烯技术提供全形态镀镍碳纤维，适配不同5G部件，支持屏蔽效能实测。</p>
      </div>

      <div style="background: var(--bg-alt); padding: 24px; border-radius: 8px; margin-top: 32px;">
        <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 12px;">相关型号推荐</h3>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>镀镍1K/3K丝编织布（60-65dB）</li>
          <li>镀镍200目粉涂料（40-50dB）</li>
          <li>镀镍短切+硅胶垫片（30-40dB）</li>
          <li>镀镍丝编织线缆屏蔽（50-60dB）</li>
        </ul>
      </div>

      <div style="text-align: center; margin-top: 32px;">
        <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; display: inline-block;">获取方案与报价</a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
