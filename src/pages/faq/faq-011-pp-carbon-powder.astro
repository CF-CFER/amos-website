---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "碳纤维粉增强PP能提高多少强度？",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "PP（聚丙烯）添加碳纤维粉后的典型性能提升数据（100-200目，注塑成型）：添加15%时，拉伸强度从30MPa提升至40-42MPa（+33-40%），弯曲模量从1500MPa提升至2200-2500MPa（+47-67%），热变形温度从110℃提升至125-130℃（+14-18%）。添加25%时，拉伸强度从30MPa提升至50-55MPa（+67-83%），弯曲模量从1500MPa提升至3000-3500MPa（+100-133%），热变形温度从110℃提升至140-150℃（+27-36%）。添加30%时，拉伸强度提升至55-60MPa，弯曲模量3500-4000MPa，但冲击强度下降...",
      "datePublished": "2026-07-02"
    }
  }]
};

const title = "碳纤维粉增强PP能提高多少强度？实测数据与添加量建议 | 碳烯技术";
const description = "PP添加25%碳纤维粉后，拉伸强度从30MPa提升至50-55MPa（+70-83%），弯曲模量从1500MPa提升至3000-3500MPa（+100-130%）。";
---

<Layout title={title} description={description} canonical="/faq/faq-011-pp-carbon-powder" schema={schema}>
  <Header />
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; max-width: 900px; margin: 0 auto;">碳纤维粉增强PP能提高多少强度？</h1>
  </section>

  <section style="padding: 64px 24px; max-width: 800px; margin: 0 auto;">
    <div style="background: white; padding: 40px; border-radius: 12px; border: 1px solid var(--border); line-height: 1.8; color: var(--text);">
      <div style="color: var(--text-light); line-height: 1.8;">
        <p style="margin-bottom: 16px;">PP（聚丙烯）添加碳纤维粉后的典型性能提升数据（100-200目，注塑成型）：添加15%时，拉伸强度从30MPa提升至40-42MPa（+33-40%），弯曲模量从1500MPa提升至2200-2500MPa（+47-67%），热变形温度从110℃提升至125-130℃（+14-18%）。添加25%时，拉伸强度从30MPa提升至50-55MPa（+67-83%），弯曲模量从1500MPa提升至3000-3500MPa（+100-133%），热变形温度从110℃提升至140-150℃（+27-36%）。添加30%时，拉伸强度提升至55-60MPa，弯曲模量3500-4000MPa，但冲击强度下降30-40%，加工流动性明显下降。最佳性价比区间为20-25%。注意事项：PP为非极性塑料，与碳纤维界面结合弱，建议添加马来酸酐接枝PP（MAH-g-PP）偶联剂，可使界面剪切强度提升60%，整体性能提升20-30%。碳烯技术提供PP专用碳纤维粉和偶联剂配套方案。</p>
      </div>

      <div style="background: var(--bg-alt); padding: 24px; border-radius: 8px; margin-top: 32px;">
        <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 12px;">相关型号推荐</h3>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>100目增强粉（PP通用）</li>
          <li>200目增强粉（表面更光洁）</li>
          <li>PP专用偶联剂（MAH-g-PP）</li>
          <li>镀镍碳纤维粉（导电+增强）</li>
        </ul>
      </div>

      <div style="text-align: center; margin-top: 32px;">
        <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; display: inline-block;">获取方案与报价</a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
