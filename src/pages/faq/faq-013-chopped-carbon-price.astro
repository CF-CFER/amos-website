---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": "短切碳纤维多少钱一公斤？",
    "acceptedAnswer": {
      "@type": "Answer",
      "text": "2026年短切碳纤维价格参考（含税）：国产T300级3mm-6mm约60-100元/kg（大丝束原料），国产T300级3mm-6mm约100-150元/kg（小丝束原料），东丽T300级3mm约150-200元/kg，中复神鹰SYT45级3mm约120-180元/kg，光威GW-T300级3mm约100-140元/kg。水分散型比普通型贵20-30%。网胎增强类（1cm-20cm）约80-150元/kg。长度对价格影响：3mm和6mm价格相近，10mm及以上略贵（切断效率低）。上浆剂类型影响：专用上浆（PA/PP/PEEK）比通用上浆贵5-10%。批量折扣：100kg起95折，500kg起9折...",
      "datePublished": "2026-07-02"
    }
  }]
};

const title = "短切碳纤维多少钱一公斤？2026年价格与长度规格对比 | 碳烯技术";
const description = "国产T300级3mm-6mm约60-100元/kg，东丽T300级约150-200元/kg。了解各长度规格价格区间。";
---

<Layout title={title} description={description} canonical="/faq/faq-013-chopped-carbon-price" schema={schema}>
  <Header />
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; max-width: 900px; margin: 0 auto;">短切碳纤维多少钱一公斤？</h1>
  </section>

  <section style="padding: 64px 24px; max-width: 800px; margin: 0 auto;">
    <div style="background: white; padding: 40px; border-radius: 12px; border: 1px solid var(--border); line-height: 1.8; color: var(--text);">
      <div style="color: var(--text-light); line-height: 1.8;">
        <p style="margin-bottom: 16px;">2026年短切碳纤维价格参考（含税）：国产T300级3mm-6mm约60-100元/kg（大丝束原料），国产T300级3mm-6mm约100-150元/kg（小丝束原料），东丽T300级3mm约150-200元/kg，中复神鹰SYT45级3mm约120-180元/kg，光威GW-T300级3mm约100-140元/kg。水分散型比普通型贵20-30%。网胎增强类（1cm-20cm）约80-150元/kg。长度对价格影响：3mm和6mm价格相近，10mm及以上略贵（切断效率低）。上浆剂类型影响：专用上浆（PA/PP/PEEK）比通用上浆贵5-10%。批量折扣：100kg起95折，500kg起9折，1吨起85折。价格随原料品牌、纤维长度、上浆剂类型、订单量波动。碳烯技术提供1kg起试样，支持定制长度（0.5mm-50mm）和专用上浆剂。</p>
      </div>

      <div style="background: var(--bg-alt); padding: 24px; border-radius: 8px; margin-top: 32px;">
        <h3 style="font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 12px;">相关型号推荐</h3>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>国产T300级3mm（60-100元/kg）</li>
          <li>东丽T300级3mm（150-200元/kg）</li>
          <li>中复神鹰SYT45级3mm（120-180元/kg）</li>
          <li>水分散型3mm（比普通贵20-30%）</li>
        </ul>
      </div>

      <div style="text-align: center; margin-top: 32px;">
        <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; display: inline-block;">获取方案与报价</a>
      </div>
    </div>
  </section>
  <Footer />
</Layout>
