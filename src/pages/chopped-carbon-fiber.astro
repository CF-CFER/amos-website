---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "短切碳纤维 - 水分散/网胎增强",
  "description": "碳烯技术短切碳纤维：水分散类（0.5mm-50mm）、网胎增强类（1cm-20cm）。适用于塑料改性、网胎增强、摩擦材料、涂料。",
  "brand": { "@type": "Brand", "name": "Amos Composites" },
  "offers": { "@type": "Offer", "availability": "https://schema.org/InStock" }
};
---

<Layout
  title="短切碳纤维_水分散_网胎增强_0.5mm-50mm短切碳纤维-碳烯技术"
  description="碳烯技术短切碳纤维供应商：水分散类（0.5mm/1mm/2mm/3mm/4mm-50mm）、网胎增强类（1cm/2cm/3cm/4cm/5cm-20cm）。适用于塑料改性、网胎增强、摩擦材料。"
  keywords="短切碳纤维,水分散短切碳纤维,网胎增强短切碳纤维,短切碳纤维3mm,短切碳纤维6mm,短切碳纤维10mm,短切碳纤维价格,短切碳纤维厂家"
  canonical="/chopped-carbon-fiber"
  schema={schema}
>
  <Header />

  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin-bottom: 12px;">
      短切碳纤维 / Chopped Carbon Fiber
    </h1>
    <p style="color: #e2e8f0; max-width: 800px; margin: 0 auto; font-size: 1.1rem;">
      水分散类 · 网胎增强类 · 全规格覆盖<br/>
      适用于塑料改性、网胎增强、摩擦材料、涂料
    </p>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
      两大产品系列
    </h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px; margin-top: 32px;">
      <div style="padding: 32px; background: var(--bg-alt); border-radius: 12px; border: 1px solid var(--border);">
        <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px;">
          💧 水分散类短切碳纤维
        </h3>
        <p style="color: var(--text-light); font-size: 0.95rem; line-height: 1.7; margin-bottom: 16px;">
          专为水性体系设计，可在水中均匀分散，适用于水性涂料、湿法成型工艺
        </p>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>常用长度：0.5mm / 1mm / 2mm / 3mm / 4mm - 50mm</li>
          <li>特点：水中分散性好，不团聚</li>
          <li>应用：水性导电涂料、湿法造纸、电池材料</li>
          <li>适用：水性环氧树脂、聚氨酯体系</li>
        </ul>
      </div>
      
      <div style="padding: 32px; background: var(--bg-alt); border-radius: 12px; border: 1px solid var(--border);">
        <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px;">
          🏗️ 网胎增强类短切碳纤维
        </h3>
        <p style="color: var(--text-light); font-size: 0.95rem; line-height: 1.7; margin-bottom: 16px;">
          专为碳纤维毡/网胎增强设计，长度较长，增强效果显著
        </p>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>常用长度：1cm / 2cm / 3cm / 4cm / 5cm - 20cm</li>
          <li>特点：纤维长，搭接效果好</li>
          <li>应用：碳纤维毡、碳碳复合材料预制体</li>
          <li>适用：真空导流、RTM、热压罐工艺</li>
        </ul>
      </div>
    </div>
  </section>

  <section style="background: var(--bg-alt); padding: 64px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
        短切碳纤维规格参数表
      </h2>
      
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; margin-top: 24px; font-size: 0.9rem;">
          <thead>
            <tr style="background: var(--primary); color: white;">
              <th style="padding: 12px; text-align: left;">长度</th>
              <th style="padding: 12px; text-align: left;">类型</th>
              <th style="padding: 12px; text-align: left;">长径比</th>
              <th style="padding: 12px; text-align: left;">含碳量</th>
              <th style="padding: 12px; text-align: left;">主要应用</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">0.5mm - 2mm</td>
              <td style="padding: 12px;">水分散</td>
              <td style="padding: 12px;">5-20</td>
              <td style="padding: 12px;">≥95%</td>
              <td style="padding: 12px;">精细涂料、电池材料</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">3mm - 6mm</td>
              <td style="padding: 12px;">水分散/塑料改性</td>
              <td style="padding: 12px;">20-60</td>
              <td style="padding: 12px;">≥95%</td>
              <td style="padding: 12px;">塑料改性、涂料</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">10mm - 20mm</td>
              <td style="padding: 12px;">塑料改性/摩擦材料</td>
              <td style="padding: 12px;">50-200</td>
              <td style="padding: 12px;">≥95%</td>
              <td style="padding: 12px;">PA/PP改性、刹车片</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">1cm - 3cm</td>
              <td style="padding: 12px;">网胎增强</td>
              <td style="padding: 12px;">100-300</td>
              <td style="padding: 12px;">≥95%</td>
              <td style="padding: 12px;">碳纤维毡、预制体</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">5cm - 20cm</td>
              <td style="padding: 12px;">网胎增强</td>
              <td style="padding: 12px;">500-2000</td>
              <td style="padding: 12px;">≥95%</td>
              <td style="padding: 12px;">碳碳复合材料、保温毡</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
      塑料改性专用短切碳纤维
    </h2>
    <p style="color: var(--text-light); text-align: center; max-width: 700px; margin: 0 auto 32px;">
      针对PA6、PA66、PP、PEEK、ABS等塑料体系优化，分散性好，界面结合力强
    </p>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px;">
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">PA6/PA66</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">3mm-6mm</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">PP</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">3mm-10mm</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">PEEK</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">3mm-6mm</p>
      </div>
      <div style="padding: 20px; background: var(--bg-alt); border-radius: 8px; text-align: center;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">ABS</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">3mm-6mm</p>
      </div>
    </div>
  </section>

  <section style="background: var(--primary); color: white; padding: 64px 24px; text-align: center;">
    <h2 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 16px;">
      获取短切碳纤维报价
    </h2>
    <p style="color: #e2e8f0; max-width: 600px; margin: 0 auto 28px; font-size: 1.05rem;">
      提供应用类型（水分散/网胎增强/塑料改性）、长度需求、数量，24小时内获取精准报价
    </p>
    <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; font-size: 1.05rem; display: inline-block;">
      获取报价 / Get Quote
    </a>
  </section>

  <Footer />
</Layout>