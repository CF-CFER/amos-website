---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "碳烯技术（深圳）有限公司 (Carbene Technology (Shenzhen) Co., Ltd.)",
  "url": "https://amoscomposites.cn",
  "logo": "https://amoscomposites.cn/logo.png",
  "description": "Leading carbon fiber materials manufacturer specializing in carbon fiber filament, chopped fiber, powder, fabric, and custom plastic modification solutions.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Shenzhen",
    "addressCountry": "CN"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "sales",
    "email": "289614365@qq.com"
  },
  "sameAs": []
};
---

<Layout
  title="碳纤维厂家_碳纤维丝_短切碳纤维_碳纤维粉-碳烯技术有限公司"
  description="碳烯技术是ISO 9001认证碳纤维厂家，专业生产碳纤维丝、短切碳纤维、碳纤维粉、碳纤维布、镀镍碳纤维。支持PA/PP/PEEK等塑料改性定制。Carbon fiber manufacturer China with 10+ years experience."
  keywords="碳纤维厂家,碳纤维供应商,碳纤维材料,碳纤维丝,短切碳纤维,碳纤维粉,碳纤维布,镀镍碳纤维,塑料改性碳纤维,carbon fiber manufacturer,carbon fiber supplier,chopped carbon fiber,carbon fiber powder,carbon fiber fabric,nickel plated carbon fiber,PAN carbon fiber,carbon fiber filament"
  canonical="/"
  schema={schema}
>
  <Header />

  <!-- Hero Section -->
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 100px 24px 80px;">
    <div style="max-width: 1200px; margin: 0 auto; text-align: center;">
      <h1 style="font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; line-height: 1.15; margin-bottom: 20px; max-width: 900px; margin-left: auto; margin-right: auto;">
        Premium Carbon Fiber Materials<br>优质碳纤维材料供应商
      </h1>
      <p style="font-size: clamp(1rem, 2vw, 1.25rem); color: #e2e8f0; max-width: 700px; margin: 0 auto 36px; line-height: 1.7;">
        ISO 9001 certified manufacturer of carbon fiber filament, chopped fiber, powder, and fabric. Trusted by automotive, aerospace, and composites industries worldwide.<br>
        ISO 9001认证制造商，产品包括碳纤维丝、短切碳纤维、碳纤维粉、碳纤维布
      </p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="/products" class="btn-primary">Explore Products</a>
        <a href="/contact" class="btn-secondary">Request Quote</a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section style="background: var(--bg-alt); padding: 40px 24px;">
    <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 24px; text-align: center;">
      <div><p style="font-size: 2rem; font-weight: 800; color: var(--primary);">10+</p><p style="color: var(--text-light); font-size: 0.9rem;">Years Experience / 年行业经验</p></div>
      <div><p style="font-size: 2rem; font-weight: 800; color: var(--primary);">18</p><p style="color: var(--text-light); font-size: 0.9rem;">Team Members / 团队成员</p></div>
      <div><p style="font-size: 2rem; font-weight: 800; color: var(--primary);">20+</p><p style="color: var(--text-light); font-size: 0.9rem;">Product Types / 产品种类</p></div>
      <div><p style="font-size: 2rem; font-weight: 800; color: var(--primary);">4</p><p style="color: var(--text-light); font-size: 0.9rem;">R&D Equipment Sets / 研发设备</p></div>
    </div>
  </section>

  <!-- Products Overview -->
  <section style="padding: 80px 24px; max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 56px;">
      <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary); margin-bottom: 12px;">Our Product Range / 产品系列</h2>
      <p style="color: var(--text-light); max-width: 600px; margin: 0 auto;">Comprehensive carbon fiber solutions for plastic modification, reinforcement, and composite manufacturing. / 全面的碳纤维改性、增强及复合材料解决方案</p>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
      <div class="product-card">
        <h3>Carbon Fiber Filament / 碳纤维丝</h3>
        <p>PAN-based and pitch-based carbon fiber filament for high-performance composites. Available in multiple specifications. / PAN基和沥青基碳纤维丝，高性能复合材料专用</p>
        <a href="/products">Learn more -&gt;</a>
      </div>
      <div class="product-card">
        <h3>Chopped Carbon Fiber / 短切碳纤维</h3>
        <p>Short-cut fibers for PA, PP, PEEK, PEI, ABS, PE, PPS, PA66, PU, PI plastic modification. Custom lengths available. / PA、PP、PEEK、PEI等塑料改性专用短切碳纤维</p>
        <a href="/products">Learn more -&gt;</a>
      </div>
      <div class="product-card">
        <h3>Carbon Fiber Powder / 碳纤维粉</h3>
        <p>Milled carbon fiber powder for conductive coatings, EMI shielding, and thermoplastic/thermoset reinforcement. / 导电涂料、电磁屏蔽专用碳纤维粉</p>
        <a href="/products">Learn more -&gt;</a>
      </div>
      <div class="product-card">
        <h3>Carbon Fiber Fabric / 碳纤维布</h3>
        <p>Woven carbon fiber fabric in various weaves (plain, twill, satin) for hand layup, RTM, and vacuum infusion processes. / 平纹、斜纹、缎纹编织碳纤维布</p>
        <a href="/products">Learn more -&gt;</a>
      </div>
      <div class="product-card">
        <h3>Nickel-Plated Fiber / 镀镍碳纤维</h3>
        <p>Electromagnetic shielding grade nickel-plated carbon fiber filament and powder for EMI/RFI applications. / 电磁屏蔽级镀镍碳纤维丝及粉末</p>
        <a href="/products">Learn more -&gt;</a>
      </div>
      <div class="product-card">
        <h3>Custom Solutions / 定制方案</h3>
        <p>Tailored fiber sizing, bundle sizing, and surface treatments for your specific resin system and processing method. / 根据客户树脂体系和加工方式定制</p>
        <a href="/contact">Request custom -&gt;</a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section style="background: var(--bg-alt); padding: 80px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 56px;">
        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary); margin-bottom: 12px;">Why Choose Amos Composites / 为什么选择我们</h2>
      </div>
      <div class="features-grid">
        <div class="feature-item">
          <div class="feature-num">01</div>
          <div>
            <h4>Quality Certifications / 质量认证</h4>
            <p>ISO 9001 certified with full MSDS, ROHS 2.0, and REACH third-party testing. / ISO 9001认证，全套MSDS、ROHS 2.0、REACH第三方检测</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-num">02</div>
          <div>
            <h4>Global Brand Partners / 品牌合作</h4>
            <p>Supplying raw materials compatible with Toray, Toho, Mitsubishi, Zoltek, Zhongfu Shenying standards. / 原料兼容东丽、东邦、三菱、卓尔泰克、中复神鹰标准</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-num">03</div>
          <div>
            <h4>R&D Capability / 研发能力</h4>
            <p>4 in-house R&D equipment sets. 4 engineers developing custom sizing and bundle solutions. / 4套研发设备，4名工程师开发定制上浆剂和束丝方案</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-num">04</div>
          <div>
            <h4>Custom Production / 定制生产</h4>
            <p>Adjust fiber length, sizing chemistry, and bundle count for PA, PP, PEEK, PEI, ABS and other matrices. / 可调整纤维长度、上浆化学成分、束丝数量</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-num">05</div>
          <div>
            <h4>Competitive Pricing / 价格优势</h4>
            <p>Factory-direct pricing with consistent batch quality. Small MOQ available for trial orders. / 工厂直供，批次质量稳定，小批量试单可接</p>
          </div>
        </div>
        <div class="feature-item">
          <div class="feature-num">06</div>
          <div>
            <h4>Fast Response / 快速响应</h4>
            <p>Technical consultation and quotation within 24 hours. Sample shipping within 3 business days. / 24小时内技术咨询和报价，3个工作日内寄样</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section style="padding: 80px 24px; max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 56px;">
      <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary); margin-bottom: 12px;">Industries We Serve / 应用领域</h2>
      <p style="color: var(--text-light); max-width: 600px; margin: 0 auto;">Our materials are used across demanding industries requiring strength, lightweight, and conductivity. / 产品广泛应用于需要高强度、轻量化和导电性的行业</p>
    </div>
    <div class="features-grid">
      <div class="industry-card"><h4>Automotive / 汽车</h4><p>Lightweight structural parts / 轻量化结构件</p></div>
      <div class="industry-card"><h4>Aerospace / 航空航天</h4><p>High-strength composites / 高强度复合材料</p></div>
      <div class="industry-card"><h4>Electronics / 电子</h4><p>EMI shielding housings / 电磁屏蔽外壳</p></div>
      <div class="industry-card"><h4>Sports Equipment / 体育器材</h4><p>Performance gear / 高性能装备</p></div>
      <div class="industry-card"><h4>Marine / 船舶</h4><p>Corrosion-resistant hulls / 耐腐蚀船体</p></div>
      <div class="industry-card"><h4>Construction / 建筑</h4><p>Structural reinforcement / 结构加固</p></div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: var(--primary); color: white; padding: 64px 24px; text-align: center;">
    <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; margin-bottom: 16px;">Ready to Strengthen Your Products? / 立即咨询</h2>
    <p style="color: #e2e8f0; max-width: 600px; margin: 0 auto 28px; font-size: 1.05rem;">Get a free technical consultation and sample quotation within 24 hours. / 24小时内获得免费技术咨询和样品报价</p>
    <a href="/contact" class="btn-cta">Request a Quote / 获取报价</a>
  </section>

  <Footer />
</Layout>
