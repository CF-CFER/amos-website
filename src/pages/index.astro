---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      "name": "碳烯技术有限公司 - 碳纤维材料厂家",
      "url": "https://amoscomposites.cn",
      "description": "ISO 9001认证碳纤维厂家，专业生产碳纤维丝、短切碳纤维、碳纤维粉、碳纤维布、镀镍碳纤维。支持PA/PP/PEEK/ABS等塑料改性定制。",
      "potentialAction": {
        "@type": "SearchAction",
        "target": { "@type": "EntryPoint", "urlTemplate": "https://amoscomposites.cn/products?q={search_term_string}" },
        "query-input": "required name=search_term_string"
      }
    },
    {
      "@type": "Organization",
      "name": "碳烯技术（深圳）有限公司",
      "alternateName": "Carbene Technology (Shenzhen) Co., Ltd.",
      "url": "https://amoscomposites.cn",
      "logo": "https://amoscomposites.cn/logo.png",
      "description": "ISO 9001认证碳纤维材料厂家，专业生产碳纤维丝、短切碳纤维、碳纤维粉、碳纤维布、镀镍碳纤维。支持PA/PP/PEEK/ABS等塑料改性定制。",
      "address": { "@type": "PostalAddress", "addressLocality": "深圳", "addressRegion": "广东", "addressCountry": "CN" },
      "contactPoint": { "@type": "ContactPoint", "contactType": "sales", "email": "289614365@qq.com", "availableLanguage": ["Chinese", "English"] },
      "sameAs": [], "foundingDate": "2015", "areaServed": "CN"
    }
  ]
}
---

<Layout
  title="碳纤维厂家_碳纤维丝_短切碳纤维_碳纤维粉-碳烯技术有限公司"
  description="碳烯技术是ISO 9001认证碳纤维厂家，专业生产碳纤维丝、短切碳纤维、碳纤维粉、碳纤维布、镀镍碳纤维。支持PA/PP/PEEK等塑料改性定制。Carbon fiber manufacturer China with 10+ years experience."
  keywords="碳纤维厂家,碳纤维供应商,碳纤维材料,碳纤维丝,短切碳纤维,碳纤维粉,碳纤维布,镀镍碳纤维,塑料改性碳纤维,carbon fiber manufacturer,carbon fiber supplier,chopped carbon fiber,carbon fiber powder,carbon fiber fabric,nickel plated carbon fiber,PAN carbon fiber,carbon fiber filament"
  canonical="/"
  schema={schema}
>
  <Header />

  <!-- Hero Section -->
  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 100px 24px 80px;">
    <div style="max-width: 1200px; margin: 0 auto; text-align: center;">
      <h1 style="font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 800; line-height: 1.15; margin-bottom: 20px; max-width: 900px; margin-left: auto; margin-right: auto;">
        Premium Carbon Fiber Materials<br>优质碳纤维材料供应商
      </h1>
      <p style="font-size: clamp(1rem, 2vw, 1.25rem); color: #e2e8f0; max-width: 700px; margin: 0 auto 36px; line-height: 1.7;">
        ISO 9001 certified manufacturer. CF T300 filament, CFRTP 20% reinforced compounds, chopped fiber (3mm-6mm) for PA/PP/PEEK/ABS modification. MSDS, RoHS 2.0, REACH compliant. MOQ 1kg trial samples available.<br>
        ISO 9001认证碳纤维厂家。CF T300碳纤维丝、CFRTP 20%增强复合料、3mm-6mm短切碳纤维（PA/PP/PEEK/ABS改性专用）。提供MSDS、RoHS 2.0、REACH检测报告。最小订货量1kg起，支持试样。
      </p>
      <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
        <a href="/products" class="btn-primary">Explore Products / 查看产品</a>
        <a href="/contact" class="btn-secondary">Request Quote & COA / 获取报价与COA</a>
      </div>
    </div>
  </section>

  <!-- Stats Bar -->
  <section style="background: var(--bg-alt); padding: 40px 24px;">
    <div style="max-width: 1200px; margin: 0 auto; display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 24px; text-align: center;">
      <div><p style="font-size: 2rem; font-weight: 800; color: var(--primary);">10+</p><p style="color: var(--text-light); font-size: 0.9rem;">Years Experience / 年行业经验</p></div>
      <div><p style="font-size: 2rem; font-weight: 800; color: var(--primary);">18</p><p style="color: var(--text-light); font-size: 0.9rem;">Team Members / 团队成员</p></div>
      <div><p style="font-size: 2rem; font-weight: 800; color: var(--primary);">20+</p><p style="color: var(--text-light); font-size: 0.9rem;">Product Types / 产品种类</p></div>
      <div><p style="font-size: 2rem; font-weight: 800; color: var(--primary);">4</p><p style="color: var(--text-light); font-size: 0.9rem;">R&D Equipment Sets / 研发设备</p></div>
    </div>
  </section>

  <!-- Products Overview -->
  <section style="padding: 80px 24px; max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 56px;">
      <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary); margin-bottom: 12px;">Our Product Range / 产品系列</h2>
      <p style="color: var(--text-light); max-width: 600px; margin: 0 auto;">Comprehensive carbon fiber solutions for plastic modification, reinforcement, and composite manufacturing. / 全面的碳纤维改性、增强及复合材料解决方案</p>
    </div>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
      <div class="product-card">
        <h3>Carbon Fiber Filament / 碳纤维丝</h3>
        <p>PAN-based and pitch-based carbon fiber filament. T300-T700 specs available. Compatible with epoxy, vinyl ester, and phenolic resin systems. / PAN基碳纤维丝，T300-T700规格，兼容环氧树脂、乙烯基酯、酚醛树脂</p>
        <div style="margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap;">
          <a href="/products" style="font-size: 0.85rem; color: var(--primary); font-weight: 600;">Learn more →</a>
          <a href="/contact" style="font-size: 0.85rem; color: var(--accent); font-weight: 600;">Inquiry / 询价</a>
        </div>
      </div>
      <div class="product-card">
        <h3>Chopped Carbon Fiber / 短切碳纤维</h3>
        <p>3mm / 6mm lengths for PA, PP, PEEK, PEI, ABS, PPS, PA66, PU, PI plastic modification. Surface sizing optimized for each matrix. / 3mm/6mm规格，PA/PP/PEEK/ABS等改性专用，上浆剂适配各基体</p>
        <div style="margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap;">
          <a href="/products" style="font-size: 0.85rem; color: var(--primary); font-weight: 600;">Learn more →</a>
          <a href="/contact" style="font-size: 0.85rem; color: var(--accent); font-weight: 600;">Get Sample / 索取样品</a>
        </div>
      </div>
      <div class="product-card">
        <h3>Carbon Fiber Powder / 碳纤维粉</h3>
        <p>80-400 mesh milled powder for conductive coatings, EMI shielding, and thermoplastic/thermoset reinforcement. / 80-400目研磨粉，导电涂料、电磁屏蔽及复合材料增强</p>
        <div style="margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap;">
          <a href="/products" style="font-size: 0.85rem; color: var(--primary); font-weight: 600;">Learn more →</a>
          <a href="/contact" style="font-size: 0.85rem; color: var(--accent); font-weight: 600;">Request COA / 获取COA</a>
        </div>
      </div>
      <div class="product-card">
        <h3>Carbon Fiber Fabric / 碳纤维布</h3>
        <p>Plain, twill, and satin weaves. 1K to 12K fiber counts. For hand layup, RTM, and vacuum infusion. / 平纹/斜纹/缎纹编织，1K-12K规格，手糊/RTM/真空导入工艺</p>
        <div style="margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap;">
          <a href="/products" style="font-size: 0.85rem; color: var(--primary); font-weight: 600;">Learn more →</a>
          <a href="/contact" style="font-size: 0.85rem; color: var(--accent); font-weight: 600;">Inquiry / 询价</a>
        </div>
      </div>
      <div class="product-card">
        <h3>Nickel-Plated Fiber / 镀镍碳纤维</h3>
        <p>Electromagnetic shielding grade. Surface resistivity ≤ 0.05 Ω·cm. For EMI/RFI housings and gaskets. / 电磁屏蔽级，表面电阻率≤0.05Ω·cm，用于EMI/RFI外壳和垫片</p>
        <div style="margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap;">
          <a href="/products" style="font-size: 0.85rem; color: var(--primary); font-weight: 600;">Learn more →</a>
          <a href="/contact" style="font-size: 0.85rem; color: var(--accent); font-weight: 600;">Inquiry / 询价</a>
        </div>
      </div>
      <div class="product-card">
        <h3>Custom Solutions / 定制方案</h3>
        <p>Tailored fiber length, sizing chemistry, and bundle count for your specific resin system and processing method. / 定制纤维长度、上浆剂配方、束丝数量，适配您的树脂体系和加工工艺</p>
        <div style="margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap;">
          <a href="/contact" style="font-size: 0.85rem; color: var(--accent); font-weight: 600;">Request Custom Quote / 定制报价</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section style="background: var(--bg-alt); padding: 80px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 56px;">
        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary); margin-bottom: 12px;">Why Choose Amos Composites / 为什么选择我们</h2>
      </div>
      <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px;">
        <div style="display: flex; gap: 16px;">
          <div style="width: 48px; height: 48px; background: var(--primary); color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">01</div>
          <div>
            <h4 style="font-weight: 700; margin-bottom: 6px;">Quality Certifications / 质量认证</h4>
            <p style="color: var(--text-light); font-size: 0.9rem;">ISO 9001 certified with full MSDS, ROHS 2.0, and REACH third-party testing. / ISO 9001认证，全套MSDS、ROHS 2.0、REACH第三方检测</p>
          </div>
        </div>
        <div style="display: flex; gap: 16px;">
          <div style="width: 48px; height: 48px; background: var(--primary); color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">02</div>
          <div>
            <h4 style="font-weight: 700; margin-bottom: 6px;">Global Brand Partners / 品牌合作</h4>
            <p style="color: var(--text-light); font-size: 0.9rem;">Supplying raw materials compatible with Toray, Toho, Mitsubishi, Zoltek, Zhongfu Shenying standards. / 原料兼容东丽、东邦、三菱、卓尔泰克、中复神鹰标准</p>
          </div>
        </div>
        <div style="display: flex; gap: 16px;">
          <div style="width: 48px; height: 48px; background: var(--primary); color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">03</div>
          <div>
            <h4 style="font-weight: 700; margin-bottom: 6px;">R&D Capability / 研发能力</h4>
            <p style="color: var(--text-light); font-size: 0.9rem;">4 in-house R&D equipment sets. 4 engineers developing custom sizing and bundle solutions. / 4套研发设备，4名工程师开发定制上浆剂和束丝方案</p>
          </div>
        </div>
        <div style="display: flex; gap: 16px;">
          <div style="width: 48px; height: 48px; background: var(--primary); color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">04</div>
          <div>
            <h4 style="font-weight: 700; margin-bottom: 6px;">Custom Production / 定制生产</h4>
            <p style="color: var(--text-light); font-size: 0.9rem;">Adjust fiber length, sizing chemistry, and bundle count for PA, PP, PEEK, PEI, ABS and other matrices. / 可调整纤维长度、上浆化学成分、束丝数量</p>
          </div>
        </div>
        <div style="display: flex; gap: 16px;">
          <div style="width: 48px; height: 48px; background: var(--primary); color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">05</div>
          <div>
            <h4 style="font-weight: 700; margin-bottom: 6px;">Competitive Pricing / 价格优势</h4>
            <p style="color: var(--text-light); font-size: 0.9rem;">Factory-direct pricing with consistent batch quality. Small MOQ available for trial orders. / 工厂直供，批次质量稳定，小批量试单可接</p>
          </div>
        </div>
        <div style="display: flex; gap: 16px;">
          <div style="width: 48px; height: 48px; background: var(--primary); color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0;">06</div>
          <div>
            <h4 style="font-weight: 700; margin-bottom: 6px;">Fast Response / 快速响应</h4>
            <p style="color: var(--text-light); font-size: 0.9rem;">Technical consultation and quotation within 24 hours. Sample shipping within 3 business days. / 24小时内技术咨询和报价，3个工作日内寄样</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Procurement FAQ / 采购常见问题 -->
  <section style="background: var(--bg-alt); padding: 80px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <div style="text-align: center; margin-bottom: 56px;">
        <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary); margin-bottom: 12px;">B2B Procurement Guide / 采购指南</h2>
        <p style="color: var(--text-light); max-width: 600px; margin: 0 auto;">What buyers ask before placing an order. / 下单前采购最关心的事</p>
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px;">
        <div style="padding: 24px; background: white; border-radius: 8px; border-left: 4px solid var(--primary);">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">📦 Minimum Order Quantity / 最小订货量</h4>
          <p style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">Standard MOQ: 25kg per spec. Trial samples: 1kg-5kg available at sample pricing. / 标准MOQ 25kg/规格。试样1kg-5kg起，按样品价供应。</p>
        </div>
        <div style="padding: 24px; background: white; border-radius: 8px; border-left: 4px solid var(--primary);">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">📋 Certifications / 认证与检测</h4>
          <p style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">ISO 9001, MSDS, RoHS 2.0, REACH. Third-party test reports available per batch. / 提供ISO 9001、MSDS、RoHS 2.0、REACH。每批次可出第三方检测报告。</p>
        </div>
        <div style="padding: 24px; background: white; border-radius: 8px; border-left: 4px solid var(--primary);">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">🚚 Lead Time & Shipping / 交期与物流</h4>
          <p style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">Stock items: 3-5 business days. Custom orders: 2-3 weeks. Sea freight / air freight / DDP available. / 现货3-5个工作日，定制2-3周。海运/空运/DDP均可。</p>
        </div>
        <div style="padding: 24px; background: white; border-radius: 8px; border-left: 4px solid var(--primary);">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">🔬 Sample Policy / 样品政策</h4>
          <p style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">Free samples up to 500g for qualified buyers. Sample shipping cost borne by buyer. / 合格买家可免费索取500g以内样品，运费由买家承担。</p>
        </div>
        <div style="padding: 24px; background: white; border-radius: 8px; border-left: 4px solid var(--primary);">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">💰 Pricing Structure / 价格结构</h4>
          <p style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">Factory-direct pricing. Volume discounts: 5% at 100kg, 10% at 500kg, 15% at 1 ton+. / 工厂直供价。100kg起95折，500kg起9折，1吨起85折。</p>
        </div>
        <div style="padding: 24px; background: white; border-radius: 8px; border-left: 4px solid var(--primary);">
          <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">🛠️ Technical Support / 技术支持</h4>
          <p style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">Free formulation consultation. Processing parameter guidance for injection molding and extrusion. / 免费提供配方咨询，注塑/挤出工艺参数指导。</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Industries -->
  <section style="padding: 80px 24px; max-width: 1200px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 56px;">
      <h2 style="font-size: 2rem; font-weight: 800; color: var(--primary); margin-bottom: 12px;">Industries We Serve / 应用领域</h2>
      <p style="color: var(--text-light); max-width: 600px; margin: 0 auto;">Our materials are used across demanding industries requiring strength, lightweight, and conductivity. / 产品广泛应用于需要高强度、轻量化和导电性的行业</p>
    </div>
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; text-align: center;">
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;"><h4 style="font-weight: 700; color: var(--primary);">Automotive / 汽车</h4><p style="color: var(--text-light); font-size: 0.85rem; margin-top: 6px;">Lightweight structural parts / 轻量化结构件</p></div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;"><h4 style="font-weight: 700; color: var(--primary);">Aerospace / 航空航天</h4><p style="color: var(--text-light); font-size: 0.85rem; margin-top: 6px;">High-strength composites / 高强度复合材料</p></div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;"><h4 style="font-weight: 700; color: var(--primary);">Electronics / 电子</h4><p style="color: var(--text-light); font-size: 0.85rem; margin-top: 6px;">EMI shielding housings / 电磁屏蔽外壳</p></div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;"><h4 style="font-weight: 700; color: var(--primary);">Sports Equipment / 体育器材</h4><p style="color: var(--text-light); font-size: 0.85rem; margin-top: 6px;">Performance gear / 高性能装备</p></div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;"><h4 style="font-weight: 700; color: var(--primary);">Marine / 船舶</h4><p style="color: var(--text-light); font-size: 0.85rem; margin-top: 6px;">Corrosion-resistant hulls / 耐腐蚀船体</p></div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;"><h4 style="font-weight: 700; color: var(--primary);">Construction / 建筑</h4><p style="color: var(--text-light); font-size: 0.85rem; margin-top: 6px;">Structural reinforcement / 结构加固</p></div>
    </div>
  </section>

  <!-- CTA -->
  <section style="background: var(--primary); color: white; padding: 64px 24px; text-align: center;">
    <h2 style="font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; margin-bottom: 16px;">Ready to Strengthen Your Products? / 立即获取报价</h2>
    <p style="color: #e2e8f0; max-width: 600px; margin: 0 auto 28px; font-size: 1.05rem;">Get a free technical consultation, COA, and sample quotation within 24 hours. MOQ 1kg for trial orders.<br>24小时内获得免费技术咨询、COA和样品报价。试样最小订货量1kg起。</p>
    <a href="/contact" class="btn-cta">Request a Quote & Sample / 获取报价与样品</a>
  </section>

  <Footer />
</Layout>
