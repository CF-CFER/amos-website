---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "碳纤维粉 - 增强专用/导电专用",
  "description": "碳烯技术碳纤维粉：增强专用碳纤维粉、导电专用碳纤维粉。50-500目全目数覆盖，适用于塑料改性、导电涂料、电磁屏蔽、摩擦材料。",
  "brand": { "@type": "Brand", "name": "Amos Composites" },
  "offers": { "@type": "Offer", "availability": "https://schema.org/InStock" }
};
---

<Layout
  title="碳纤维粉_增强专用_导电专用_50-500目碳纤维粉-碳烯技术"
  description="碳烯技术碳纤维粉供应商：增强专用碳纤维粉、导电专用碳纤维粉。50目-500目全规格，适用于塑料改性增强、导电涂料、电磁屏蔽、摩擦材料。获取碳纤维粉报价。"
  keywords="碳纤维粉,增强专用碳纤维粉,导电专用碳纤维粉,碳纤维粉50目,碳纤维粉100目,碳纤维粉200目,碳纤维粉300目,碳纤维粉500目,碳纤维粉价格"
  canonical="/carbon-fiber-powder"
  schema={schema}
>
  <Header />

  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin-bottom: 12px;">
      碳纤维粉 / Carbon Fiber Powder
    </h1>
    <p style="color: #e2e8f0; max-width: 800px; margin: 0 auto; font-size: 1.1rem;">
      增强专用 · 导电专用 · 50-500目全规格<br/>
      适用于塑料改性、导电涂料、电磁屏蔽、摩擦材料
    </p>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
      两大产品系列
    </h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px; margin-top: 32px;">
      <div style="padding: 32px; background: var(--bg-alt); border-radius: 12px; border: 1px solid var(--border);">
        <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px;">
          🔧 增强专用碳纤维粉
        </h3>
        <p style="color: var(--text-light); font-size: 0.95rem; line-height: 1.7; margin-bottom: 16px;">
          专为塑料改性增强设计，提升复合材料的力学性能和耐热性
        </p>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>适用：PA、PP、PEEK、ABS等热塑性塑料</li>
          <li>效果：拉伸强度提升30-50%</li>
          <li>效果：弯曲模量提升50-100%</li>
          <li>效果：热变形温度提升20-40℃</li>
          <li>常用目数：100目、200目、300目</li>
        </ul>
      </div>
      
      <div style="padding: 32px; background: var(--bg-alt); border-radius: 12px; border: 1px solid var(--border);">
        <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px;">
          ⚡ 导电专用碳纤维粉
        </h3>
        <p style="color: var(--text-light); font-size: 0.95rem; line-height: 1.7; margin-bottom: 16px;">
          专为导电应用设计，用于导电涂料、电磁屏蔽、防静电材料
        </p>
        <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.8;">
          <li>适用：导电涂料、EMI屏蔽涂料</li>
          <li>表面电阻率：10²-10⁴ Ω/sq</li>
          <li>屏蔽效能：40-60 dB</li>
          <li>体积电阻率：10⁻²-10¹ Ω·cm</li>
          <li>常用目数：50目、100目、200目</li>
        </ul>
      </div>
    </div>
  </section>

  <section style="background: var(--bg-alt); padding: 64px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
        碳纤维粉规格参数表
      </h2>
      
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; margin-top: 24px; font-size: 0.9rem;">
          <thead>
            <tr style="background: var(--primary); color: white;">
              <th style="padding: 12px; text-align: left;">目数</th>
              <th style="padding: 12px; text-align: left;">粒径范围</th>
              <th style="padding: 12px; text-align: left;">长径比</th>
              <th style="padding: 12px; text-align: left;">堆积密度</th>
              <th style="padding: 12px; text-align: left;">含碳量</th>
              <th style="padding: 12px; text-align: left;">主要应用</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">50目</td>
              <td style="padding: 12px;">~300μm</td>
              <td style="padding: 12px;">5-10</td>
              <td style="padding: 12px;">0.3-0.5 g/cm³</td>
              <td style="padding: 12px;">≥95%</td>
              <td style="padding: 12px;">摩擦材料、刹车片</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">100目</td>
              <td style="padding: 12px;">~150μm</td>
              <td style="padding: 12px;">10-20</td>
              <td style="padding: 12px;">0.25-0.4 g/cm³</td>
              <td style="padding: 12px;">≥95%</td>
              <td style="padding: 12px;">导电涂料、塑料改性</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">200目</td>
              <td style="padding: 12px;">~75μm</td>
              <td style="padding: 12px;">15-30</td>
              <td style="padding: 12px;">0.2-0.35 g/cm³</td>
              <td style="padding: 12px;">≥95%</td>
              <td style="padding: 12px;">精密塑料改性、涂料</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">300目</td>
              <td style="padding: 12px;">~50μm</td>
              <td style="padding: 12px;">20-40</td>
              <td style="padding: 12px;">0.18-0.3 g/cm³</td>
              <td style="padding: 12px;">≥95%</td>
              <td style="padding: 12px;">高端涂料、特种塑料</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">500目</td>
              <td style="padding: 12px;">~30μm</td>
              <td style="padding: 12px;">30-60</td>
              <td style="padding: 12px;">0.15-0.25 g/cm³</td>
              <td style="padding: 12px;">≥95%</td>
              <td style="padding: 12px;">特种涂料、精细塑料</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
      应用领域
    </h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; text-align: center; margin-top: 32px;">
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">塑料改性</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">PA/PP/PEEK增强</p>
      </div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">导电涂料</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">防静电/电磁屏蔽</p>
      </div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">摩擦材料</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">刹车片/离合器片</p>
      </div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px;">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">建筑材料</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">导电地坪/发热材料</p>
      </div>
    </div>
  </section>

  <section style="background: var(--primary); color: white; padding: 64px 24px; text-align: center;">
    <h2 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 16px;">
      获取碳纤维粉报价
    </h2>
    <p style="color: #e2e8f0; max-width: 600px; margin: 0 auto 28px; font-size: 1.05rem;">
      提供应用类型（增强/导电）、目数需求、数量，24小时内获取精准报价
    </p>
    <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; font-size: 1.05rem; display: inline-block;">
      获取报价 / Get Quote
    </a>
  </section>

  <Footer />
</Layout>