        </div>
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">M系列 - 高模量</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>M40J - 高模量 377GPa</li>
            <li>M46J - 超高模量 436GPa</li>
            <li>M50J - 顶级模量 475GPa</li>
            <li>M55J - 最高模量 540GPa</li>
            <li>M60J - 超顶级模量 588GPa</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- 东邦 -->
    <div style="margin-bottom: 32px; padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
      <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px; border-bottom: 2px solid var(--primary); padding-bottom: 8px;">
        东邦 Toho Tenax（日本）
      </h3>
