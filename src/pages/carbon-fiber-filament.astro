---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "各品牌碳纤维丝 - 碳烯技术合作品牌集成",
  "description": "碳烯技术合作品牌碳纤维丝：东丽T300/T700/T800/T1100/MJ、东邦HTA/HTS/HR、三菱K13D2、中复神鹰SYT/SYM、光威GW、恒神HF、吉林化纤等。1K-24K全规格，PAN基/沥青基双体系，支持定制上浆剂和表面处理。",
  "brand": { "@type": "Brand", "name": "碳烯技术" },
  "offers": { "@type": "Offer", "availability": "https://schema.org/InStock" }
};
---

<Layout
  title="碳纤维丝_1K/3K/6K/12K/24K_各品牌合作碳纤维丝-碳烯技术"
  description="碳烯技术合作品牌碳纤维丝供应商：东丽T300/T700/T800/MJ、东邦HTA/HTS/HR、三菱K13D2、中复神鹰SYT/SYM、光威GW、恒神HF、吉林化纤。1K-24K全规格覆盖，PAN基/沥青基双体系，支持定制上浆剂和表面处理。一站比货，快速报价。"
  keywords="碳纤维丝,碳纤维丝1K,碳纤维丝3K,碳纤维丝6K,碳纤维丝12K,碳纤维丝24K,东丽碳纤维丝,T300碳纤维丝,T700碳纤维丝,T800碳纤维丝,中复神鹰碳纤维丝,光威碳纤维丝,碳纤维丝价格,碳纤维丝厂家"
  canonical="/carbon-fiber-filament"
  schema={schema}
>
  <Header />

  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin-bottom: 12px;">
      碳纤维丝 / Carbon Fiber Filament
    </h1>
    <p style="color: #e2e8f0; max-width: 800px; margin: 0 auto; font-size: 1.1rem;">
      合作品牌碳纤维丝一站式供应：东丽、东邦、三菱、中复神鹰、光威、恒神、吉林化纤、台丽<br/>
      1K-24K全规格覆盖，PAN基/沥青基双体系，一站比货，快速报价
    </p>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
      品牌系列型号 / Brand Series Model
    </h2>
    <p style="color: var(--text-light); text-align: center; max-width: 700px; margin: 0 auto 40px;">
      碳烯技术与国内外主流碳纤维丝品牌建立稳定合作关系，按品牌-系列-型号分类，方便您快速找到所需产品
    </p>
    
    <!-- 东丽 -->
    <div style="margin-bottom: 32px; padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
      <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px; border-bottom: 2px solid var(--primary); padding-bottom: 8px;">
        东丽 Toray（日本）
      </h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px;">
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">T系列 - 标准/高强度</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>T300 - 标准模量 230GPa</li>
            <li>T400H - 高强度 250GPa</li>
            <li>T700S - 超高强度 230GPa</li>
            <li>T700G - 高模量 240GPa</li>
            <li>T800S - 顶级强度 294GPa</li>
            <li>T800H - 航空级 294GPa</li>
            <li>T1100G - 最高强度 324GPa</li>
          </ul>
        </div>
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">M系列 - 高模量</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>M40J - 高模量 377GPa</li>
            <li>M46J - 超高模量 436GPa</li>
            <li>M50J - 顶级模量 475GPa</li>
            <li>M55J - 最高模量 540GPa</li>
            <li>M60J - 超顶级模量 588GPa</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- 东邦 -->
    <div style="margin-bottom: 32px; padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
      <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px; border-bottom: 2px solid var(--primary); padding-bottom: 8px;">
        东邦 Toho Tenax（日本）
      </h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px;">
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">HT系列 - 标准强度</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>HTA40 - 标准模量 240GPa</li>
            <li>HTS40 - 标准模量 240GPa</li>
            <li>HTS45 - 高强度 250GPa</li>
          </ul>
        </div>
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">IMS系列 - 中间模量</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>IMS40 - 中间模量 290GPa</li>
            <li>IMS60 - 高模量 300GPa</li>
          </ul>
        </div>
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">UMS系列 - 超高模量</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>UMS40 - 超高模量 390GPa</li>
            <li>UMS45 - 顶级模量 430GPa</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- 三菱 -->
    <div style="margin-bottom: 32px; padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
      <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px; border-bottom: 2px solid var(--primary); padding-bottom: 8px;">
        三菱化学 Mitsubishi（日本）
      </h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px;">
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">PYROFIL系列</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>TR30S - 标准模量 230GPa</li>
            <li>TR50S - 高强度 240GPa</li>
            <li>TRH50 - 超高强度 250GPa</li>
            <li>MR40 - 中间模量 280GPa</li>
            <li>MR50 - 高模量 290GPa</li>
          </ul>
        </div>
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">沥青基系列</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>K13D2U - 高模量 540GPa</li>
            <li>K13C2U - 超高模量 620GPa</li>
            <li>K13C6U - 顶级模量 860GPa</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- 中复神鹰 -->
    <div style="margin-bottom: 32px; padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
      <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px; border-bottom: 2px solid var(--primary); padding-bottom: 8px;">
        中复神鹰 Zhongfu Shenying（中国）
      </h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px;">
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">SYT系列 - T300-T800级</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>SYT35 - T300级 230GPa</li>
            <li>SYT45 - T700级 230GPa</li>
            <li>SYT49 - T700S级 240GPa</li>
            <li>SYT55S - T800级 290GPa</li>
            <li>SYT65 - T1000级 300GPa</li>
          </ul>
        </div>
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">SYM系列 - 高模量</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>SYM40 - M40J级 375GPa</li>
            <li>SYM46 - M46J级 435GPa</li>
            <li>SYM50 - M50J级 475GPa</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- 光威复材 -->
    <div style="margin-bottom: 32px; padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
      <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px; border-bottom: 2px solid var(--primary); padding-bottom: 8px;">
        光威复材 GW（中国）
      </h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px;">
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">GQ系列 - 通用级</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>GQ3522 - T300级 230GPa</li>
            <li>GQ4522 - T700级 240GPa</li>
          </ul>
        </div>
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">TZ系列 - 高性能</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>TZ300 - 高强中模 270GPa</li>
            <li>TZ500J - 高模量 350GPa</li>
            <li>TZ700S - 超高强 300GPa</li>
            <li>TZ800H - 航空级 294GPa</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- 恒神 -->
    <div style="margin-bottom: 32px; padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
      <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px; border-bottom: 2px solid var(--primary); padding-bottom: 8px;">
        恒神 Hengshen（中国）
      </h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px;">
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">HF系列</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>HF10 - T300级 230GPa</li>
            <li>HF20 - T700级 240GPa</li>
            <li>HF30 - T800级 290GPa</li>
            <li>HF40 - T1000级 300GPa</li>
            <li>HF50J - M40J级 377GPa</li>
            <li>HF55J - M55J级 540GPa</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- 吉林化纤 -->
    <div style="margin-bottom: 32px; padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
      <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px; border-bottom: 2px solid var(--primary); padding-bottom: 8px;">
        吉林化纤 Jilin Chemical Fiber（中国）
      </h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px;">
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">1K/3K/6K/12K/24K</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>1K - 小丝束，高端体育器材</li>
            <li>3K - 标准丝束，预浸料/编织</li>
            <li>6K - 工业级，拉挤型材</li>
            <li>12K - 大丝束，建筑加固</li>
            <li>24K - 大丝束，风电叶片</li>
            <li>48K - 超大丝束，低成本应用</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- 台丽 -->
    <div style="margin-bottom: 32px; padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
      <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px; border-bottom: 2px solid var(--primary); padding-bottom: 8px;">
        台丽 Formosa Plastics（台湾）
      </h3>
      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 16px;">
        <div>
          <h4 style="font-weight: 700; color: var(--text); margin-bottom: 8px;">TC35/TC36系列</h4>
          <ul style="color: var(--text-light); font-size: 0.9rem; line-height: 1.6;">
            <li>TC35 - 标准模量 230GPa</li>
            <li>TC36 - 高强度 240GPa</li>
            <li>TC42 - 超高强度 250GPa</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section style="background: var(--bg-alt); padding: 64px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
        碳纤维丝规格参数 / Specifications
      </h2>
      
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; margin-top: 24px; font-size: 0.9rem;">
          <thead>
            <tr style="background: var(--primary); color: white;">
              <th style="padding: 12px; text-align: left;">品牌</th>
              <th style="padding: 12px; text-align: left;">型号</th>
              <th style="padding: 12px; text-align: left;">丝束</th>
              <th style="padding: 12px; text-align: left;">拉伸强度</th>
              <th style="padding: 12px; text-align: left;">弹性模量</th>
              <th style="padding: 12px; text-align: left;">适用场景</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">东丽</td>
              <td style="padding: 12px;">T300</td>
              <td style="padding: 12px;">1K/3K/6K/12K</td>
              <td style="padding: 12px;">3.53 GPa</td>
              <td style="padding: 12px;">230 GPa</td>
              <td style="padding: 12px;">体育器材、汽车配件</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">东丽</td>
              <td style="padding: 12px;">T700S</td>
              <td style="padding: 12px;">12K/24K</td>
              <td style="padding: 12px;">4.90 GPa</td>
              <td style="padding: 12px;">230 GPa</td>
              <td style="padding: 12px;">航空航天、压力容器</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">东丽</td>
              <td style="padding: 12px;">T800S</td>
              <td style="padding: 12px;">12K/24K</td>
              <td style="padding: 12px;">5.88 GPa</td>
              <td style="padding: 12px;">294 GPa</td>
              <td style="padding: 12px;">高端航空、军工</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">东丽</td>
              <td style="padding: 12px;">M40J</td>
              <td style="padding: 12px;">3K/6K/12K</td>
              <td style="padding: 12px;">4.41 GPa</td>
              <td style="padding: 12px;">377 GPa</td>
              <td style="padding: 12px;">卫星、高端体育</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">东邦</td>
              <td style="padding: 12px;">HTS40</td>
              <td style="padding: 12px;">3K/6K/12K/24K</td>
              <td style="padding: 12px;">4.10 GPa</td>
              <td style="padding: 12px;">240 GPa</td>
              <td style="padding: 12px;">汽车、工业</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">三菱</td>
              <td style="padding: 12px;">TR50S</td>
              <td style="padding: 12px;">12K/24K</td>
              <td style="padding: 12px;">4.90 GPa</td>
              <td style="padding: 12px;">240 GPa</td>
              <td style="padding: 12px;">汽车、压力容器</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">中复神鹰</td>
              <td style="padding: 12px;">SYT45</td>
              <td style="padding: 12px;">3K/6K/12K</td>
              <td style="padding: 12px;">4.50 GPa</td>
              <td style="padding: 12px;">230 GPa</td>
              <td style="padding: 12px;">体育器材、汽车</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">中复神鹰</td>
              <td style="padding: 12px;">SYT55S</td>
              <td style="padding: 12px;">6K/12K/24K</td>
              <td style="padding: 12px;">5.80 GPa</td>
              <td style="padding: 12px;">290 GPa</td>
              <td style="padding: 12px;">航空航天、军工</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">光威</td>
              <td style="padding: 12px;">TZ700S</td>
              <td style="padding: 12px;">12K/24K</td>
              <td style="padding: 12px;">4.90 GPa</td>
              <td style="padding: 12px;">294 GPa</td>
              <td style="padding: 12px;">航空、汽车</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">恒神</td>
              <td style="padding: 12px;">HF30</td>
              <td style="padding: 12px;">12K/24K</td>
              <td style="padding: 12px;">5.50 GPa</td>
              <td style="padding: 12px;">290 GPa</td>
              <td style="padding: 12px;">高端工业、航空</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">吉林化纤</td>
              <td style="padding: 12px;">12K/24K/48K</td>
              <td style="padding: 12px;">大丝束</td>
              <td style="padding: 12px;">≥3.5 GPa</td>
              <td style="padding: 12px;">≥230 GPa</td>
              <td style="padding: 12px;">风电、建筑、汽车</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
      PAN基 vs 沥青基碳纤维丝
    </h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px; margin-top: 32px;">
      <div style="padding: 32px; background: var(--bg-alt); border-radius: 12px; border: 1px solid var(--border);">
        <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px;">PAN基碳纤维丝</h3>
        <ul style="color: var(--text-light); font-size: 0.95rem; line-height: 1.8;">
          <li>原料：聚丙烯腈（PAN）</li>
          <li>特点：强度高、韧性好</li>
          <li>强度：3.5-7.0 GPa</li>
          <li>模量：230-300 GPa</li>
          <li>代表：T300、T700、T800、SYT45</li>
          <li>应用：体育器材、汽车、航空</li>
        </ul>
      </div>
      
      <div style="padding: 32px; background: var(--bg-alt); border-radius: 12px; border: 1px solid var(--border);">
        <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px;">沥青基碳纤维丝</h3>
        <ul style="color: var(--text-light); font-size: 0.95rem; line-height: 1.8;">
          <li>原料：石油/煤沥青</li>
          <li>特点：模量高、导热好</li>
          <li>强度：2.0-3.5 GPa</li>
          <li>模量：300-900 GPa</li>
          <li>代表：M40J、M55J、K13D2U</li>
          <li>应用：卫星、高端体育器材</li>
        </ul>
      </div>
    </div>
  </section>

  <section style="background: var(--primary); color: white; padding: 64px 24px; text-align: center;">
    <h2 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 16px;">
