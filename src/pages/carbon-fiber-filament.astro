---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "各品牌碳纤维丝 - 碳烯技术合作品牌集成",
  "description": "碳烯技术合作品牌碳纤维丝：东丽、东邦、三菱、台丽、中复神鹰、碳谷、拓展、光威。1K-24K全规格，PAN基/沥青基双体系，支持定制上浆剂和表面处理。",
  "brand": { "@type": "Brand", "name": "碳烯技术" },
  "offers": { "@type": "Offer", "availability": "https://schema.org/InStock" }
};
---

<Layout
  title="碳纤维丝_1K/3K/6K/12K/24K_各品牌合作碳纤维丝-碳烯技术"
  description="碳烯技术合作品牌碳纤维丝供应商：东丽、东邦、三菱、台丽、中复神鹰、碳谷、拓展、光威。1K-24K全规格覆盖，PAN基/沥青基双体系，支持定制上浆剂和表面处理。一站比货，快速报价。"
  keywords="碳纤维丝,碳纤维丝1K,碳纤维丝3K,碳纤维丝6K,碳纤维丝12K,碳纤维丝24K,东丽碳纤维丝,中复神鹰碳纤维丝,光威碳纤维丝,碳纤维丝价格,碳纤维丝厂家"
  canonical="/carbon-fiber-filament"
  schema={schema}
>
  <Header />

  <section style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); color: white; padding: 80px 24px 60px; text-align: center;">
    <h1 style="font-size: clamp(1.8rem, 4vw, 2.8rem); font-weight: 800; margin-bottom: 12px;">
      碳纤维丝 / Carbon Fiber Filament
    </h1>
    <p style="color: #e2e8f0; max-width: 800px; margin: 0 auto; font-size: 1.1rem;">
      合作品牌碳纤维丝一站式供应：东丽、东邦、三菱、台丽、中复神鹰、碳谷、拓展、光威<br/>
      1K-24K全规格覆盖，PAN基/沥青基双体系，一站比货，快速报价
    </p>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
      合作品牌 / Partner Brands
    </h2>
    <p style="color: var(--text-light); text-align: center; max-width: 700px; margin: 0 auto 40px;">
      碳烯技术与国内外主流碳纤维丝品牌建立稳定合作关系，为客户提供多品牌比价、一站式采购服务
    </p>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; text-align: center;">
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">Toray / 东丽</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">日本第一品牌<br/>T300/T700/T800/M40/M55</p>
      </div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">Toho / 东邦</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">日本高性能碳纤维<br/>Tenax系列</p>
      </div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">Mitsubishi / 三菱</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">日本沥青基碳纤维<br/>高模量系列</p>
      </div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">Formosa / 台丽</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">台湾碳纤维品牌<br/>性价比高</p>
      </div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">中复神鹰</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">国产碳纤维龙头<br/>SYT系列</p>
      </div>
      <div style="padding: 24px; background: var(--bg-alt); border-radius: 8px; border: 1px solid var(--border);">
        <h4 style="font-weight: 700; color: var(--primary); margin-bottom: 8px;">碳谷 / 拓展 / 光威</h4>
        <p style="color: var(--text-light); font-size: 0.85rem;">国产碳纤维品牌<br/>多样化规格</p>
      </div>
    </div>
  </section>

  <section style="background: var(--bg-alt); padding: 64px 24px;">
    <div style="max-width: 1200px; margin: 0 auto;">
      <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
        碳纤维丝规格参数 / Specifications
      </h2>
      
      <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; margin-top: 24px; font-size: 0.9rem;">
          <thead>
            <tr style="background: var(--primary); color: white;">
              <th style="padding: 12px; text-align: left;">规格</th>
              <th style="padding: 12px; text-align: left;">单丝数量</th>
              <th style="padding: 12px; text-align: left;">直径</th>
              <th style="padding: 12px; text-align: left;">拉伸强度</th>
              <th style="padding: 12px; text-align: left;">弹性模量</th>
              <th style="padding: 12px; text-align: left;">适用场景</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">1K</td>
              <td style="padding: 12px;">1000根</td>
              <td style="padding: 12px;">~0.2mm</td>
              <td style="padding: 12px;">≥3.5 GPa</td>
              <td style="padding: 12px;">≥230 GPa</td>
              <td style="padding: 12px;">高端体育器材、无人机</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">3K</td>
              <td style="padding: 12px;">3000根</td>
              <td style="padding: 12px;">~0.3mm</td>
              <td style="padding: 12px;">≥3.5 GPa</td>
              <td style="padding: 12px;">≥230 GPa</td>
              <td style="padding: 12px;">碳纤维布编织、预浸料</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">6K</td>
              <td style="padding: 12px;">6000根</td>
              <td style="padding: 12px;">~0.4mm</td>
              <td style="padding: 12px;">≥3.5 GPa</td>
              <td style="padding: 12px;">≥230 GPa</td>
              <td style="padding: 12px;">拉挤型材、工业复合材料</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border); background: var(--bg);">
              <td style="padding: 12px; font-weight: 700;">12K</td>
              <td style="padding: 12px;">12000根</td>
              <td style="padding: 12px;">~0.5mm</td>
              <td style="padding: 12px;">≥3.5 GPa</td>
              <td style="padding: 12px;">≥230 GPa</td>
              <td style="padding: 12px;">建筑加固、风电叶片</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border);">
              <td style="padding: 12px; font-weight: 700;">24K</td>
              <td style="padding: 12px;">24000根</td>
              <td style="padding: 12px;">~0.7mm</td>
              <td style="padding: 12px;">≥3.5 GPa</td>
              <td style="padding: 12px;">≥230 GPa</td>
              <td style="padding: 12px;">大型复合材料构件</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section style="padding: 64px 24px; max-width: 1200px; margin: 0 auto;">
    <h2 style="font-size: 1.8rem; font-weight: 800; color: var(--primary); margin-bottom: 16px; text-align: center;">
      PAN基 vs 沥青基碳纤维丝
    </h2>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 32px; margin-top: 32px;">
      <div style="padding: 32px; background: var(--bg-alt); border-radius: 12px; border: 1px solid var(--border);">
        <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px;">PAN基碳纤维丝</h3>
        <ul style="color: var(--text-light); font-size: 0.95rem; line-height: 1.8;">
          <li>原料：聚丙烯腈（PAN）</li>
          <li>特点：强度高、韧性好</li>
          <li>强度：3.5-7.0 GPa</li>
          <li>模量：230-300 GPa</li>
          <li>代表型号：T300、T700、T800</li>
          <li>应用：体育器材、汽车、航空</li>
        </ul>
      </div>
      
      <div style="padding: 32px; background: var(--bg-alt); border-radius: 12px; border: 1px solid var(--border);">
        <h3 style="font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-bottom: 16px;">沥青基碳纤维丝</h3>
        <ul style="color: var(--text-light); font-size: 0.95rem; line-height: 1.8;">
          <li>原料：石油/煤沥青</li>
          <li>特点：模量高、导热好</li>
          <li>强度：2.0-3.5 GPa</li>
          <li>模量：300-900 GPa</li>
          <li>代表型号：M40、M55、M60J</li>
          <li>应用：卫星、高端体育器材</li>
        </ul>
      </div>
    </div>
  </section>

  <section style="background: var(--primary); color: white; padding: 64px 24px; text-align: center;">
    <h2 style="font-size: 1.8rem; font-weight: 800; margin-bottom: 16px;">
      获取碳纤维丝报价
    </h2>
    <p style="color: #e2e8f0; max-width: 600px; margin: 0 auto 28px; font-size: 1.05rem;">
      提供所需品牌、规格、数量，24小时内获取精准报价
    </p>
    <a href="/contact" style="background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; font-size: 1.05rem; display: inline-block;">
      获取报价 / Get Quote
    </a>
  </section>

  <Footer />
</Layout>