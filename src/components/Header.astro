---
const current = Astro.url.pathname;

const navItems = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' }
];

const products = [
  { label: 'Carbon Fiber Tow', href: '/products#filament' },
  { label: 'Carbon Fiber Yarn', href: '/products#filament' },
  { label: 'Carbon filament', href: '/products#filament' },
  { label: 'Milled Carbon Fiber', href: '/products#powder' },
  { label: 'Chopped Carbon Fiber Tow', href: '/products#chopped' },
  { label: 'Carbon Fiber Fabric', href: '/products#fabric' }
];
---
<header>
  <div class="header-container">
    <!-- 左侧：公司名称 -->
    <a href="/" class="logo">
      <div class="logo-cn">碳烯技术有限公司</div>
      <div class="logo-en">Carbene Technology Co., Ltd.</div>
    </a>

    <!-- 右侧区域 -->
    <div class="header-right">
      <!-- 右上角：产品列表（小字） -->
      <div class="product-list">
        <a href="/products" class="product-main">Products / 产品</a>
        <span class="divider">|</span>
        {products.map((item, index) => (
          <>
            <a href={item.href} class="product-item">{item.label}</a>
            {index < products.length - 1 && <span class="divider">·</span>}
          </>
        ))}
      </div>
      
      <!-- 右下角：导航 + 按钮 -->
      <div class="nav-row">
        <nav>
          <ul class="nav-menu">
            {navItems.map(item => (
              <li>
                <a href={item.href} class={`nav-link ${current === item.href ? 'nav-active' : ''}`}>
                  {item.label}
                </a>
              </li>
            ))}
          </ul>
        </nav>
        <a href="/contact" class="btn-nav">Get Quote</a>
      </div>
    </div>
  </div>
</header>
<style>
  header {
    background: var(--primary);
    color: white;
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 8px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: 64px;
  }
  .logo {
    font-weight: 800;
    font-size: 1.25rem;
    color: white;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }
  .logo-cn {
    font-size: 1.25rem;
    font-weight: 800;
  }
  .logo-en {
    font-size: 0.65rem;
    font-weight: 500;
    opacity: 0.85;
    letter-spacing: 0.5px;
    margin-top: 2px;
  }
  .header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 4px;
  }
  /* 右上角产品列表 */
  .product-list {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: flex-end;
  }
  .product-main {
    color: #ffd700;
    font-size: 0.7rem;
    font-weight: 600;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .product-main:hover {
    color: white;
  }
  .product-item {
    color: #cbd5e0;
    font-size: 0.65rem;
    text-decoration: none;
    transition: color 0.2s;
    white-space: nowrap;
  }
  .product-item:hover {
    color: white;
  }
  .divider {
    color: #4a5568;
    font-size: 0.6rem;
  }
  /* 右下角导航 */
  .nav-row {
    display: flex;
    align-items: center;
    gap: 20px;
  }
  .nav-menu {
    display: flex;
    gap: 20px;
    list-style: none;
    align-items: center;
    margin: 0;
    padding: 0;
  }
  .nav-link {
    font-weight: 500;
    font-size: 0.9rem;
    color: white;
    text-decoration: none;
    padding: 4px 0;
    border-bottom: 2px solid transparent;
    transition: border-color 0.2s, opacity 0.2s;
    white-space: nowrap;
  }
  .nav-link:hover {
    opacity: 0.8;
    border-bottom-color: rgba(255,255,255,0.5);
  }
  .nav-active {
    border-bottom-color: white;
  }
  .btn-nav {
    background: var(--accent);
    color: white;
    padding: 6px 16px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.85rem;
    text-decoration: none;
    transition: background 0.2s;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .btn-nav:hover {
    background: #9b2c2c;
  }
  
  @media (max-width: 768px) {
    .header-container {
      flex-direction: column;
      align-items: stretch;
      padding: 10px 16px;
      gap: 8px;
      min-height: auto;
    }
    .logo {
      text-align: center;
    }
    .logo-cn {
      font-size: 1.1rem;
    }
    .logo-en {
      font-size: 0.6rem;
    }
    .header-right {
      align-items: center;
      gap: 6px;
    }
    .product-list {
      justify-content: center;
    }
    .nav-row {
      justify-content: center;
      gap: 16px;
    }
    .nav-menu {
      gap: 16px;
    }
  }
  @media (max-width: 480px) {
    .header-container {
      padding: 8px 12px;
    }
    .logo-cn {
      font-size: 1rem;
    }
    .logo-en {
      font-size: 0.55rem;
    }
    .product-item {
      font-size: 0.6rem;
    }
    .nav-link {
      font-size: 0.8rem;
    }
    .btn-nav {
      padding: 5px 12px;
      font-size: 0.75rem;
    }
    .nav-menu {
      gap: 12px;
    }
  }
</style>
