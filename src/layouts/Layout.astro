---
const { title, description, keywords, canonical, schema = {} } = Astro.props;
---
<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content={keywords} />
  <meta name="author" content="Amos Composites Technology (Shenzhen) Co., Ltd." />
  <meta name="robots" content="index, follow" />
  
  <!-- 搜索引擎验证标签 - 请替换为实际验证代码 -->
  <!-- Google Search Console: <meta name="google-site-verification" content="YOUR_CODE" /> -->
  <!-- 百度站长: <meta name="baidu-site-verification" content="YOUR_CODE" /> -->
  
  <!-- Canonical -->
  <link rel="canonical" href={`https://amoscomposites.cn${canonical || ''}`} />
  
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={`https://amoscomposites.cn${canonical || ''}`} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content="https://amoscomposites.cn/og-image.jpg" />
  <meta property="og:site_name" content="Amos Composites" />
  
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content="https://amoscomposites.cn/og-image.jpg" />
  
  <!-- Schema.org -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  
  <!-- Performance optimizations -->
  <link rel="dns-prefetch" href="https://amoscomposites.cn" />
  <link rel="preconnect" href="https://amoscomposites.cn" crossorigin />
  
  <!-- System fonts - no external requests for faster loading in China -->
  
  <style is:global>
    :root {
      --primary: #1a365d;
      --primary-light: #2c5282;
      --accent: #c53030;
      --text: #1a202c;
      --text-light: #4a5568;
      --bg: #ffffff;
      --bg-alt: #f7fafc;
      --border: #e2e8f0;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji'; color: var(--text); line-height: 1.6; }
    img { max-width: 100%; height: auto; }
    a { text-decoration: none; color: inherit; }
    ul { list-style: none; }
    
    /* Button Styles */
    .btn-primary { background: white; color: var(--primary); padding: 14px 32px; border-radius: 8px; font-weight: 700; font-size: 1rem; display: inline-block; }
    .btn-secondary { background: transparent; color: white; padding: 14px 32px; border-radius: 8px; font-weight: 700; font-size: 1rem; border: 2px solid white; display: inline-block; }
    .btn-cta { background: var(--accent); color: white; padding: 16px 40px; border-radius: 8px; font-weight: 700; font-size: 1.05rem; display: inline-block; }
    
    /* Product Card */
    .product-card { background: var(--bg); border: 1px solid var(--border); border-radius: 12px; padding: 32px; }
    .product-card h3 { font-size: 1.15rem; font-weight: 700; color: var(--primary); margin-bottom: 10px; }
    .product-card p { color: var(--text-light); font-size: 0.9rem; line-height: 1.6; }
    .product-card a { display: inline-block; margin-top: 16px; color: var(--accent); font-weight: 600; font-size: 0.9rem; }
    
    /* Feature Item */
    .feature-item { display: flex; gap: 16px; }
    .feature-num { width: 48px; height: 48px; background: var(--primary); color: white; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-weight: 700; flex-shrink: 0; }
    .feature-item h4 { font-weight: 700; margin-bottom: 6px; }
    .feature-item p { color: var(--text-light); font-size: 0.9rem; }
    
    /* Industry Card */
    .industry-card { padding: 24px; background: var(--bg-alt); border-radius: 8px; }
    .industry-card h4 { font-weight: 700; color: var(--primary); }
    .industry-card p { color: var(--text-light); font-size: 0.85rem; margin-top: 6px; }
    
    /* Mobile Optimizations */
    @media (max-width: 768px) {
      .product-card { padding: 20px; }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
